---
/**
 * Rota /contato — redireciona pra home com hash #contato, que abre o modal.
 * Em produção o Firebase Hosting faz 301 (ver firebase.json); este template
 * é fallback pra dev local (Astro dev server) e navegadores sem JS.
 */
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0; url=/#contato" />
    <link rel="canonical" href="/" />
    <title>Redirecionando... | Safras & Negócios</title>
    <script is:inline>
      window.location.replace("/#contato");
    </script>
  </head>
  <body>
    <p style="font-family: system-ui, sans-serif; padding: 2rem;">
      Redirecionando... Se nada acontecer,
      <a href="/#contato">clique aqui</a>.
    </p>
  </body>
</html>
