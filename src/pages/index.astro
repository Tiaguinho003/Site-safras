  <script>
    const cards = document.querySelectorAll<HTMLElement>("[data-service-card]");

    const activate = (target: HTMLElement) => {
      cards.forEach((card) => {
        card.dataset.active = card === target ? "true" : "false";
      });
    };

    cards.forEach((card) => {
      card.addEventListener("mouseenter", () => activate(card));
      card.addEventListener("focus", () => activate(card));
    });
  </script>

  <script>
    const counters = document.querySelectorAll<HTMLElement>("[data-counter]");
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    const formatBR = (n: number) => n.toLocaleString("pt-BR");

    if (prefersReducedMotion) {
      counters.forEach((el) => {
        const target = parseInt(el.dataset.target ?? "0", 10);
        el.textContent = formatBR(target);
      });
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const el = entry.target as HTMLElement;
            const target = parseInt(el.dataset.target ?? "0", 10);
            const duration = parseInt(el.dataset.duration ?? "1800", 10);
            const start = performance.now();

            const tick = (now: number) => {
              const elapsed = now - start;
              const progress = Math.min(elapsed / duration, 1);
              // easeOutQuart: desaceleração mais acentuada no fim, dá sensação
              // de "settling" natural (vs cubic que terminava abrupto)
              const eased = 1 - Math.pow(1 - progress, 4);
              const current = Math.floor(eased * target);
              el.textContent = formatBR(current);
              if (progress < 1) requestAnimationFrame(tick);
            };

            requestAnimationFrame(tick);
            observer.unobserve(el);
          });
        },
        { threshold: 0.3 }
      );

      counters.forEach((el) => observer.observe(el));
    }
  </script>

  <style>
    #hero-titulo {
      text-shadow:
        0 2px 6px rgba(0, 0, 0, 0.45),
        0 6px 20px rgba(0, 0, 0, 0.3);
    }

    .word-rotator {
      display: inline-grid;
      grid-template-areas: "stack";
      vertical-align: baseline;
      overflow: hidden;
      padding-top: 0.16em;
      padding-bottom: 0.06em;
      padding-left: 0.18em;
    }
    .word-rotator__word {
      grid-area: stack;
      transition:
        transform 1100ms cubic-bezier(0.22, 1, 0.36, 1),
        opacity 850ms cubic-bezier(0.4, 0, 0.2, 1);
      will-change: transform, opacity;
    }
    .word-rotator__word[data-state="active"] {
      transform: translateY(0);
      opacity: 1;
    }
    .word-rotator__word[data-state="exit"] {
      transform: translateY(-32%);
      opacity: 0;
    }
    .word-rotator__word[data-state="queued"] {
      transform: translateY(32%);
      opacity: 0;
    }
    @media (prefers-reduced-motion: reduce) {
      .word-rotator__word {
        transition: none;
      }
    }

    .split-text-word {
      display: inline-block;
      opacity: 0;
      transform: translateX(28px);
      transition:
        opacity 750ms cubic-bezier(0.22, 1, 0.36, 1),
        transform 750ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    .split-text.is-revealed .split-text-word {
      opacity: 1;
      transform: translateX(0);
    }

    .fade-in-up {
      opacity: 0;
      transform: translateY(28px);
      transition:
        opacity 800ms cubic-bezier(0.22, 1, 0.36, 1) 200ms,
        transform 800ms cubic-bezier(0.22, 1, 0.36, 1) 200ms;
    }
    .fade-in-up.is-revealed {
      opacity: 1;
      transform: translateY(0);
    }

    /* About — 3 cards de stats. No md+, background-attachment:fixed
       ancora a imagem na viewport, e cada card vira uma "janela"
       pra mesma imagem (efeito parallax + divisão natural). */
    .stats-card {
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    }
    @media (min-width: 768px) {
      .stats-card {
        background-attachment: fixed;
      }
    }

    /* About — nome da cidade: mask slide-up por linha (editorial).
       O wrapper recebe .is-revealed do observer; CSS aciona descendentes. */
    .city-line {
      transform: translateY(110%);
      transition: transform 1000ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    .city-name-wrap.is-revealed .city-line {
      transform: translateY(0);
    }
    .city-line-label {
      opacity: 0;
      transform: translateY(8px);
      transition:
        opacity 700ms cubic-bezier(0.22, 1, 0.36, 1),
        transform 700ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    .city-name-wrap.is-revealed .city-line-label {
      opacity: 1;
      transform: translateY(0);
    }

    /* About — counter card: fade-up suave do grupo todo enquanto o JS conta. */
    .counter-group {
      opacity: 0;
      transform: translateY(12px);
      transition:
        opacity 800ms cubic-bezier(0.22, 1, 0.36, 1),
        transform 800ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    .counter-group.is-revealed {
      opacity: 1;
      transform: translateY(0);
    }

    /* About — fade dos icon-boxes (opacity-only — transform criaria
       containing block e quebraria background-attachment:fixed dos filhos) */
    .reveal-icon-box {
      opacity: 0;
      transition: opacity 700ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    .reveal-icon-box.is-revealed {
      opacity: 1;
    }

    /* About — bandeira do icon-box: cai do topo + leve balanço final.
       transform-origin no topo simula fixação como bandeira pendurada. */
    .icon-flag .flag-content {
      transform: translateY(-100%);
      transform-origin: top center;
    }
    .reveal-icon-box.is-revealed .icon-flag .flag-content {
      animation: flag-drop 1100ms cubic-bezier(0.22, 1, 0.36, 1) var(--flag-delay, 0ms) forwards;
    }
    @keyframes flag-drop {
      0%   { transform: translateY(-100%) rotate(0deg); }
      55%  { transform: translateY(0)     rotate(0deg); }
      72%  { transform: translateY(0)     rotate(2.5deg); }
      86%  { transform: translateY(0)     rotate(-1.5deg); }
      100% { transform: translateY(0)     rotate(0deg); }
    }

    /* About — grão de café flutuante (2 wrappers: float externo + tilt interno) */
    .coffee-bean-float {
      animation: coffee-bean-float 4s ease-in-out infinite;
      will-change: transform;
    }
    .coffee-bean-tilt {
      animation: coffee-bean-tilt 5s ease-in-out infinite;
      will-change: transform;
      transform-origin: center;
    }
    @keyframes coffee-bean-float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-10px); }
    }
    @keyframes coffee-bean-tilt {
      0%, 100% { transform: rotate(-10deg); }
      50% { transform: rotate(10deg); }
    }

    @media (prefers-reduced-motion: reduce) {
      .split-text-word,
      .fade-in-up,
      .reveal-icon-box,
      .city-line,
      .city-line-label,
      .counter-group {
        opacity: 1;
        transform: none;
        transition: none;
      }
      .icon-flag .flag-content {
        transform: none;
        animation: none;
      }
      .coffee-bean-float,
      .coffee-bean-tilt {
        animation: none;
      }
    }

    .scroll-mouse-dot {
      animation: scroll-mouse-dot 1.8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    }
    @keyframes scroll-mouse-dot {
      0% {
        transform: translateY(0);
        opacity: 0;
      }
      20% {
        opacity: 1;
      }
      80% {
        opacity: 1;
      }
      100% {
        transform: translateY(10px);
        opacity: 0;
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .scroll-mouse-dot {
        animation: none;
      }
    }
  </style>

