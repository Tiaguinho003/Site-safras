---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import lavouraDeCafe from "../assets/hero/lavoura-de-cafe.png";
import provaDeXicara from "../assets/hero/prova-de-xicara.jpg";

const stats = [
  { target: 10, suffix: "+", label: "Anos de mercado" },
  { target: 1200, suffix: "+", label: "Produtores atendidos" },
  { target: 500, suffix: "", label: "Mil sacas negociadas por ano" },
  { target: 8, suffix: "", label: "Estados de atuação" },
];

const steps = [
  {
    number: "01",
    title: "Relacionamento",
    description:
      "Conhecemos o produtor, a cooperativa ou o comprador. Entendemos cada necessidade antes de qualquer número ir pro papel.",
  },
  {
    number: "02",
    title: "Negociação",
    description:
      "Levantamos preço, volume e condições. Conectamos as pontas no momento certo — sem afobação, sem prejuízo.",
  },
  {
    number: "03",
    title: "Logística",
    description:
      "Coordenamos armazenagem, transporte e entrega. Acompanhamos o café sair do terreiro até chegar onde precisa.",
  },
  {
    number: "04",
    title: "Liquidação",
    description:
      "Conferimos peso, classificação e pagamento. Relação que não termina no contrato — segue pra próxima safra.",
  },
];

const posts = [
  {
    category: "Notícias",
    date: "22 abr 2026",
    title: "Cotação do arábica renova máxima histórica com clima seco em Minas",
    excerpt:
      "A soma de geada fora de época e irregularidade nas chuvas pressiona o preço na ICE Futures desde janeiro.",
    href: "/noticias",
  },
  {
    category: "Blog",
    date: "15 abr 2026",
    title: "Como a classificação sensorial influencia o preço final da saca",
    excerpt:
      "Prova de xícara não é formalidade — é o detalhe que decide se uma saca vale bebida dura, mole ou riada.",
    href: "/blog",
  },
  {
    category: "Notícias",
    date: "08 abr 2026",
    title: "Safra 2026/27 projeta recorde em volumes exportáveis do Brasil",
    excerpt:
      "Levantamentos do Cecafé apontam colheita robusta, mesmo com adversidades pontuais no Cerrado Mineiro.",
    href: "/noticias",
  },
];

const services = [
  {
    number: "01",
    title: "Corretagem de café",
    description:
      "Intermediamos a negociação entre produtor e comprador com neutralidade e leitura de mercado, assegurando preço justo, contrato claro e pagamento em dia.",
    iconSvg: `<path d="m11 17 2 2a1 1 0 1 0 3-3" /><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4" /><path d="m21 3 1 11h-2" /><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3" /><path d="M3 4h8" />`,
  },
  {
    number: "02",
    title: "Assessoria de mercado",
    description:
      "Inteligência de preços, análise de safra e acompanhamento macroeconômico para orientar decisões de venda, hedge e planejamento de longo prazo.",
    iconSvg: `<polyline points="22 7 13.5 15.5 8.5 10.5 2 17" /><polyline points="16 7 22 7 22 13" />`,
  },
  {
    number: "03",
    title: "Classificação e qualidade",
    description:
      "Prova de xícara e classificação sensorial executadas por profissionais experientes, lote por lote — agregando valor e garantindo padrão na entrega.",
    iconSvg: `<path d="M17 8h1a4 4 0 1 1 0 8h-1" /><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z" /><line x1="6" x2="6" y1="2" y2="4" /><line x1="10" x2="10" y1="2" y2="4" /><line x1="14" x2="14" y1="2" y2="4" />`,
  },
  {
    number: "04",
    title: "Seguros rurais",
    description:
      "Proteção do produtor contra adversidades climáticas e riscos de safra, com soluções desenhadas pra realidade do café — previsibilidade da lavoura à colheita.",
    iconSvg: `<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" /><path d="m9 12 2 2 4-4" />`,
  },
];
---

<BaseLayout title="Safras & Negócios | Corretora de café">
  <section
    class="relative -mt-32 md:-mt-36 min-h-[100svh] flex flex-col items-center overflow-hidden"
    aria-labelledby="hero-titulo"
  >
    <div
      class="absolute inset-0 -z-10 overflow-hidden"
      aria-hidden="true"
    >
      <Image
        src={lavouraDeCafe}
        alt=""
        widths={[1200, 1600, 2000]}
        sizes="100vw"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-black/25"></div>
      <div
        class="absolute inset-0"
        style="background: linear-gradient(180deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0) 28%, rgba(0,0,0,0) 60%, rgba(0,0,0,0.5) 100%);"
      >
      </div>
    </div>

    <div
      class="relative max-w-5xl w-full mx-auto px-6 md:px-10 pt-44 md:pt-56 text-center text-paper"
    >
      <span
        class="inline-block text-[11px] md:text-xs font-semibold uppercase tracking-[0.28em] text-paper/85 mb-6 md:mb-8"
      >
        Corretora de café
      </span>

      <h1
        id="hero-titulo"
        class="uppercase leading-[0.95] tracking-tight"
      >
        <span
          class="word-rotator hero-title-top block font-light text-paper text-5xl sm:text-6xl md:text-7xl lg:text-8xl xl:text-[7rem] tracking-[-0.01em]"
          aria-live="polite"
        >
          <span class="word-rotator__word" data-state="active">Tradição</span>
          <span class="word-rotator__word" data-state="queued" aria-hidden="true"
            >Confiança</span
          >
        </span>
        <span
          class="hero-title-divider block my-3 md:my-5 mx-auto"
          aria-hidden="true"
        ></span>
        <span
          class="hero-title-bottom block font-normal text-[#E8C07A] text-xl sm:text-2xl md:text-3xl lg:text-4xl xl:text-5xl"
        >
          no mercado de café
        </span>
      </h1>

      <p
        class="mt-8 md:mt-10 max-w-xl mx-auto text-base md:text-lg text-paper/90 leading-relaxed drop-shadow-[0_1px_12px_rgba(0,0,0,0.4)]"
      >
        Conectamos origem e mercado com a seriedade de quem entende de café.<br
          class="hidden md:inline"
        /> Há mais de 10 safras.
      </p>

    </div>

    <button
      type="button"
      data-scroll-next
      aria-label="Ir para a próxima seção"
      class="absolute bottom-8 md:bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-paper/70 hover:text-paper transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-paper/80 focus-visible:ring-offset-2 focus-visible:ring-offset-transparent rounded-full p-2"
    >
      <span
        class="relative block w-6 h-10 rounded-full border border-paper/60"
        aria-hidden="true"
      >
        <span
          class="scroll-mouse-dot absolute top-2 left-1/2 w-1 h-2 bg-paper/85 rounded-full -translate-x-1/2"
        ></span>
      </span>
    </button>
  </section>

  <section
    id="proximo"
    class="bg-paper border-t border-line scroll-mt-20 md:scroll-mt-28"
    aria-labelledby="servicos-titulo"
  >
    <div class="max-w-[100rem] mx-auto px-6 md:px-10 py-20 md:py-28 lg:py-32">
      <div
        class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-14 md:mb-20"
      >
        <div class="max-w-2xl">
          <span
            class="inline-block text-xs font-semibold uppercase tracking-[0.22em] text-brand mb-5"
          >
            [ Serviços ]
          </span>
          <h2
            id="servicos-titulo"
            class="text-3xl md:text-4xl lg:text-[2.75rem] font-semibold text-ink leading-[1.1] tracking-tight"
          >
            Do grão ao negócio, com quem
            <span class="text-brand">conhece o café por dentro.</span>
          </h2>
          <p class="mt-5 text-base md:text-lg text-ink-muted leading-relaxed max-w-xl">
            Três frentes de atuação que, juntas, garantem que cada saca saia
            da lavoura pro mercado certo — no momento certo, no preço justo.
          </p>
        </div>

        <a
          href="/servicos"
          class="inline-flex items-center gap-1.5 text-brand hover:text-brand-dark font-medium text-sm whitespace-nowrap border-b border-brand/30 hover:border-brand pb-1 self-start md:self-auto md:mb-2 transition-colors"
        >
          Ver todos os serviços
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div
        id="servicos-accordion"
        class="flex flex-col md:flex-row gap-4 md:gap-5 md:h-[500px] lg:h-[540px]"
      >
        {
          services.map((service, idx) => (
            <article
              data-service-card
              data-active={idx === 0 ? "true" : "false"}
              class="group relative overflow-hidden rounded-xl bg-paper-alt border border-dashed border-line cursor-pointer flex-1 md:flex-[1_1_0%] data-[active=true]:md:flex-[2.5_1_0%] data-[active=true]:border-solid data-[active=true]:border-brand-dark h-[320px] md:h-full transition-[flex,border-color] duration-500 ease-[cubic-bezier(0.29,0,0.2,1)] focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-4"
              tabindex="0"
              aria-label={`Serviço ${service.number}: ${service.title}`}
            >
              <div
                aria-hidden="true"
                class="absolute inset-0 bg-paper/90 group-data-[active=true]:bg-[linear-gradient(180deg,rgba(19,64,36,0)_20%,rgba(1,61,1,0.95)_100%)] transition-all duration-[600ms] ease-[cubic-bezier(0.48,0,0.11,1)]"
              />

              <div class="relative h-full p-6 md:p-7 flex flex-col justify-between">
                <div class="flex items-start justify-between gap-4">
                  <div
                    class="w-12 h-12 md:w-14 md:h-14 rounded-xl flex items-center justify-center bg-ink text-brand group-data-[active=true]:bg-brand group-data-[active=true]:text-paper transition-colors duration-500 ease-[cubic-bezier(0.48,0,0.11,1)] shrink-0"
                    aria-hidden="true"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      set:html={service.iconSvg}
                    />
                  </div>
                  <span
                    class="text-4xl md:text-5xl lg:text-6xl font-semibold text-paper leading-none tracking-tight opacity-0 group-data-[active=true]:opacity-100 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] delay-[700ms]"
                    aria-hidden="true"
                  >
                    {service.number}
                  </span>
                </div>

                <div>
                  <h3 class="sr-only">{service.title}</h3>

                  <div class="grid" aria-hidden="true">
                    <span
                      class="col-start-1 row-start-1 self-end text-base md:text-lg font-semibold text-ink leading-[1.2] tracking-tight line-clamp-2 transition-opacity duration-[300ms] ease-[cubic-bezier(0.48,0,0.11,1)] group-data-[active=true]:opacity-0"
                    >
                      {service.title}
                    </span>
                    <span
                      class="col-start-1 row-start-1 self-end text-xl md:text-2xl lg:text-3xl font-semibold text-paper leading-[1.15] tracking-tight line-clamp-2 opacity-0 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] delay-[300ms] group-data-[active=true]:opacity-100"
                    >
                      {service.title}
                    </span>
                  </div>

                  <div
                    class="h-px bg-paper/40 my-4 md:my-5 opacity-0 group-data-[active=true]:opacity-100 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] delay-[700ms]"
                    aria-hidden="true"
                  />
                  <p
                    class="text-sm md:text-base text-paper/90 leading-relaxed opacity-0 group-data-[active=true]:opacity-100 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] delay-[700ms]"
                  >
                    {service.description}
                  </p>
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <p class="mt-10 text-xs italic text-ink-muted/70">
        ⚠ Conteúdo dos serviços em rascunho — confirmar descrições com a
        Safras antes de publicar.
      </p>
    </div>
  </section>

  <section
    class="bg-paper-alt border-t border-line"
    aria-labelledby="quem-somos-titulo"
  >
    <div class="max-w-[100rem] mx-auto px-6 md:px-10 py-20 md:py-28 lg:py-32">
      <div
        class="grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-12 lg:gap-20 items-center"
      >
        <div class="order-2 lg:order-1">
          <div
            class="relative aspect-[4/5] rounded-xl bg-paper border border-dashed border-line overflow-hidden flex items-center justify-center shadow-[0_30px_60px_-30px_rgba(20,19,17,0.2)]"
            role="img"
            aria-label="Imagem ilustrativa de Quem Somos — em breve"
          >
            <span class="text-xs text-ink-muted/70 italic">
              Imagem em breve
            </span>
          </div>
        </div>

        <div class="order-1 lg:order-2 max-w-2xl">
          <span
            class="inline-block text-xs font-semibold uppercase tracking-[0.22em] text-brand mb-5"
          >
            [ Quem somos ]
          </span>

          <h2
            id="quem-somos-titulo"
            class="text-3xl md:text-4xl lg:text-[2.75rem] font-semibold text-ink leading-[1.1] tracking-tight"
          >
            Uma casa feita de
            <span class="text-brand">confiança e proximidade.</span>
          </h2>

          <div
            class="mt-6 space-y-5 text-base md:text-lg text-ink-muted leading-relaxed"
          >
            <p>
              Conectamos produtores, cooperativas e exportadores com a seriedade 
              de quem entende de mercado e o prazer de quem aprecia um bom café.  
            </p>
            <p>
              Somos feitos de relação. Contratos claros, palavra cumprida,
              presença no campo e em cada mesa de negociação. Quando a Safras
              entra numa operação, as duas pontas sabem o que esperar.
            </p>
          </div>

          <div class="mt-10">
            <a
              href="/quem-somos"
              class="inline-flex items-center gap-1.5 text-brand hover:text-brand-dark font-medium text-sm border-b border-brand/30 hover:border-brand pb-1 transition-colors"
            >
              Conheça nossa história
              <span aria-hidden="true">→</span>
            </a>
          </div>

          <p class="mt-10 text-xs italic text-ink-muted/70">
            ⚠ Conteúdo em rascunho — confirmar textos com a Safras antes de
            publicar.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section
    class="bg-paper border-t border-line"
    aria-labelledby="numeros-titulo"
  >
    <div class="max-w-[100rem] mx-auto px-6 md:px-10 py-20 md:py-28 lg:py-32">
      <div class="max-w-2xl mb-14 md:mb-20">
        <span
          class="inline-block text-xs font-semibold uppercase tracking-[0.22em] text-brand mb-5"
        >
          [ Números ]
        </span>
        <h2
          id="numeros-titulo"
          class="text-3xl md:text-4xl lg:text-[2.75rem] font-semibold text-ink leading-[1.1] tracking-tight"
        >
          Nossa história em <span class="text-brand">números.</span>
        </h2>
        <p class="mt-5 text-base md:text-lg text-ink-muted leading-relaxed">
          Décadas de relação, milhares de produtores atendidos e centenas de
          milhares de sacas negociadas — a seriedade da Safras medida no que
          importa.
        </p>
      </div>

      <div
        class="grid grid-cols-2 lg:grid-cols-4 gap-10 md:gap-12 lg:gap-8 border-t border-line pt-12 md:pt-16"
      >
        {
          stats.map((stat) => (
            <div>
              <div class="flex items-baseline tabular-nums">
                <span
                  data-counter
                  data-target={stat.target}
                  class="text-4xl md:text-5xl lg:text-[3.75rem] font-semibold text-brand leading-none tracking-tight"
                >
                  0
                </span>
                {stat.suffix && (
                  <span class="text-2xl md:text-3xl lg:text-4xl font-semibold text-brand/70 leading-none tracking-tight ml-0.5">
                    {stat.suffix}
                  </span>
                )}
              </div>
              <p class="mt-3 md:mt-4 text-sm md:text-base text-ink-muted leading-snug max-w-[20ch]">
                {stat.label}
              </p>
            </div>
          ))
        }
      </div>

      <p class="mt-12 md:mt-16 text-xs italic text-ink-muted/70">
        ⚠ Números em rascunho — substituir pelos valores reais da Safras
        antes de publicar.
      </p>
    </div>
  </section>

  <section
    class="bg-paper-alt border-t border-line"
    aria-labelledby="timeline-titulo"
  >
    <div class="max-w-[100rem] mx-auto px-6 md:px-10 py-20 md:py-28 lg:py-32">
      <div class="max-w-2xl mb-14 md:mb-20">
        <span
          class="inline-block text-xs font-semibold uppercase tracking-[0.22em] text-brand mb-5"
        >
          [ Como trabalhamos ]
        </span>
        <h2
          id="timeline-titulo"
          class="text-3xl md:text-4xl lg:text-[2.75rem] font-semibold text-ink leading-[1.1] tracking-tight"
        >
          Do primeiro aperto de mão
          <span class="text-brand">à última saca entregue.</span>
        </h2>
        <p class="mt-5 text-base md:text-lg text-ink-muted leading-relaxed">
          Um fluxo claro, sem surpresas — com a Safras presente em cada
          etapa da operação.
        </p>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 md:gap-8 lg:gap-10"
      >
        {
          steps.map((step) => (
            <div class="relative">
              <div
                class="w-14 h-14 rounded-full bg-brand flex items-center justify-center text-paper font-semibold text-base tracking-tight shadow-[0_12px_32px_-12px_rgba(2,92,0,0.55)]"
                aria-hidden="true"
              >
                {step.number}
              </div>
              <h3 class="mt-6 text-xl md:text-2xl font-semibold text-ink leading-snug tracking-tight">
                {step.title}
              </h3>
              <p class="mt-3 text-sm md:text-base text-ink-muted leading-relaxed">
                {step.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section
    class="bg-paper border-t border-line"
    aria-labelledby="mercado-titulo"
  >
    <div class="max-w-[100rem] mx-auto px-6 md:px-10 py-20 md:py-28 lg:py-32">
      <div
        class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-14 md:mb-20"
      >
        <div class="max-w-2xl">
          <span
            class="inline-block text-xs font-semibold uppercase tracking-[0.22em] text-brand mb-5"
          >
            [ Mercado ]
          </span>
          <h2
            id="mercado-titulo"
            class="text-3xl md:text-4xl lg:text-[2.75rem] font-semibold text-ink leading-[1.1] tracking-tight"
          >
            Notícias e análises que
            <span class="text-brand">movem o café.</span>
          </h2>
          <p class="mt-5 text-base md:text-lg text-ink-muted leading-relaxed">
            Acompanhe o mercado com curadoria Safras — cotações, safras e
            cenário macro.
          </p>
        </div>
        <a
          href="/noticias"
          class="inline-flex items-center gap-1.5 text-brand hover:text-brand-dark font-medium text-sm whitespace-nowrap border-b border-brand/30 hover:border-brand pb-1 self-start md:self-auto md:mb-2 transition-colors"
        >
          Ver todas as notícias
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6 lg:gap-10">
        {
          posts.map((post) => (
            <article class="group">
              <a
                href={post.href}
                class="block focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-4 rounded-lg"
              >
                <div class="relative aspect-[3/2] rounded-lg bg-paper-alt border border-dashed border-line overflow-hidden flex items-center justify-center transition-colors duration-300 group-hover:border-brand/40">
                  <span class="text-xs italic text-ink-muted/70 transition-colors duration-300 group-hover:text-brand/70">
                    Imagem em breve
                  </span>
                </div>
                <div class="mt-5 flex items-center gap-2 text-xs uppercase tracking-[0.18em] text-ink-muted">
                  <span class="text-brand font-semibold">{post.category}</span>
                  <span aria-hidden="true">·</span>
                  <time>{post.date}</time>
                </div>
                <h3 class="mt-3 text-lg md:text-xl font-semibold text-ink leading-snug tracking-tight line-clamp-3 transition-colors duration-300 group-hover:text-brand">
                  {post.title}
                </h3>
                <p class="mt-3 text-sm text-ink-muted leading-relaxed line-clamp-2">
                  {post.excerpt}
                </p>
                <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-brand">
                  Ler mais
                  <span
                    class="transition-transform duration-300 group-hover:translate-x-1"
                    aria-hidden="true"
                  >
                    →
                  </span>
                </span>
              </a>
            </article>
          ))
        }
      </div>

      <p class="mt-12 text-xs italic text-ink-muted/70">
        ⚠ Posts exemplo — substituir por conteúdo real antes de publicar.
      </p>
    </div>
  </section>

  <section class="bg-brand-dark" aria-labelledby="cta-final-titulo">
    <div
      class="max-w-4xl mx-auto px-6 md:px-10 py-20 md:py-28 lg:py-32 text-center"
    >
      <span
        class="inline-block text-xs font-semibold uppercase tracking-[0.22em] text-paper/60 mb-5"
      >
        [ Vamos conversar ]
      </span>
      <h2
        id="cta-final-titulo"
        class="text-3xl md:text-4xl lg:text-5xl font-semibold text-paper leading-[1.1] tracking-tight"
      >
        Uma conversa pode mudar a sua safra.
      </h2>
      <p class="mt-6 text-base md:text-lg text-paper/80 leading-relaxed max-w-2xl mx-auto">
        Conte pra gente o que você precisa — vender café, comprar lote ou
        entender o mercado. Respondemos rápido e sem compromisso.
      </p>
      <div class="mt-10">
        <button
          type="button"
          data-open-contact
          class="inline-flex items-center gap-1.5 bg-paper hover:bg-paper-alt text-ink text-base font-medium px-7 py-3.5 rounded-full transition-colors duration-200"
        >
          Solicitar Serviço
          <span aria-hidden="true">→</span>
        </button>
      </div>
    </div>
  </section>

  <script>
    const cards = document.querySelectorAll<HTMLElement>("[data-service-card]");

    const activate = (target: HTMLElement) => {
      cards.forEach((card) => {
        card.dataset.active = card === target ? "true" : "false";
      });
    };

    cards.forEach((card) => {
      card.addEventListener("mouseenter", () => activate(card));
      card.addEventListener("focus", () => activate(card));
    });
  </script>

  <script>
    const counters = document.querySelectorAll<HTMLElement>("[data-counter]");
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    const formatBR = (n: number) => n.toLocaleString("pt-BR");

    if (prefersReducedMotion) {
      counters.forEach((el) => {
        const target = parseInt(el.dataset.target ?? "0", 10);
        el.textContent = formatBR(target);
      });
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const el = entry.target as HTMLElement;
            const target = parseInt(el.dataset.target ?? "0", 10);
            const duration = 1600;
            const start = performance.now();

            const tick = (now: number) => {
              const elapsed = now - start;
              const progress = Math.min(elapsed / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              const current = Math.floor(eased * target);
              el.textContent = formatBR(current);
              if (progress < 1) requestAnimationFrame(tick);
            };

            requestAnimationFrame(tick);
            observer.unobserve(el);
          });
        },
        { threshold: 0.3 }
      );

      counters.forEach((el) => observer.observe(el));
    }
  </script>

  <style>
    .hero-title-top .word-rotator__word {
      color: var(--color-paper);
      text-shadow:
        0 2px 6px rgba(0, 0, 0, 0.45),
        0 6px 20px rgba(0, 0, 0, 0.3);
    }
    .hero-title-divider {
      height: 2px;
      width: 32%;
      border-radius: 2px;
      background: linear-gradient(
        to right,
        rgba(255, 255, 255, 0) 0%,
        rgba(255, 255, 255, 0.95) 25%,
        rgba(255, 255, 255, 0.95) 75%,
        rgba(255, 255, 255, 0) 100%
      );
      filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.5));
      transform-origin: center;
      /* Sincroniza com o word-rotator: INTERVAL_MS=3500, TRANSITION_MS=750 */
      animation: hero-divider-sync 3500ms cubic-bezier(0.65, 0, 0.35, 1) 3500ms infinite backwards;
    }
    @keyframes hero-divider-sync {
      0%    { transform: scaleX(1); }
      10.7% { transform: scaleX(0); }
      21.4% { transform: scaleX(1); }
      100%  { transform: scaleX(1); }
    }
    @media (prefers-reduced-motion: reduce) {
      .hero-title-divider {
        animation: none;
      }
    }
    .hero-title-bottom {
      letter-spacing: 0.04em;
      text-shadow:
        0 2px 6px rgba(0, 0, 0, 0.55),
        0 4px 16px rgba(0, 0, 0, 0.35);
    }

    .word-rotator {
      display: inline-grid;
      grid-template-areas: "stack";
      vertical-align: baseline;
      overflow: hidden;
      padding-top: 0.16em;
      padding-bottom: 0.06em;
    }
    .word-rotator__word {
      grid-area: stack;
      transition:
        transform 800ms cubic-bezier(0.65, 0, 0.35, 1),
        opacity 600ms cubic-bezier(0.65, 0, 0.35, 1);
      will-change: transform, opacity;
    }
    .word-rotator__word[data-state="active"] {
      transform: translateY(0);
      opacity: 1;
    }
    .word-rotator__word[data-state="exit"],
    .word-rotator__word[data-state="queued"] {
      transform: translateY(100%);
      opacity: 0;
    }
    @media (prefers-reduced-motion: reduce) {
      .word-rotator__word {
        transition: none;
      }
    }

    .scroll-mouse-dot {
      animation: scroll-mouse-dot 1.8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    }
    @keyframes scroll-mouse-dot {
      0% {
        transform: translate(-50%, 0);
        opacity: 0;
      }
      20% {
        opacity: 1;
      }
      80% {
        opacity: 1;
      }
      100% {
        transform: translate(-50%, 10px);
        opacity: 0;
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .scroll-mouse-dot {
        animation: none;
      }
    }
  </style>

  <script>
    const scrollNextBtn = document.querySelector<HTMLButtonElement>(
      "[data-scroll-next]"
    );
    scrollNextBtn?.addEventListener("click", () => {
      document
        .getElementById("proximo")
        ?.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  </script>

  <script>
    const rotator = document.querySelector<HTMLElement>(".word-rotator");
    if (rotator) {
      const words = Array.from(
        rotator.querySelectorAll<HTMLElement>(".word-rotator__word")
      );
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      if (words.length > 1 && !prefersReducedMotion) {
        let activeIdx = 0;
        const INTERVAL_MS = 3500;
        const TRANSITION_MS = 750;

        const rotate = () => {
          const nextIdx = (activeIdx + 1) % words.length;
          const current = words[activeIdx];
          const next = words[nextIdx];

          current.setAttribute("data-state", "exit");
          next.setAttribute("data-state", "queued");

          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              next.setAttribute("data-state", "active");
            });
          });

          window.setTimeout(() => {
            current.setAttribute("data-state", "queued");
          }, TRANSITION_MS);

          activeIdx = nextIdx;
        };

        window.setInterval(rotate, INTERVAL_MS);
      }
    }
  </script>
</BaseLayout>
