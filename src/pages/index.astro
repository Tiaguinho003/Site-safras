  <script>
    const cards = document.querySelectorAll<HTMLElement>("[data-service-card]");

    const activate = (target: HTMLElement) => {
      cards.forEach((card) => {
        card.dataset.active = card === target ? "true" : "false";
      });
    };

    cards.forEach((card) => {
      card.addEventListener("mouseenter", () => activate(card));
      card.addEventListener("focus", () => activate(card));
    });
  </script>

  <script>
    const counters = document.querySelectorAll<HTMLElement>("[data-counter]");
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    const formatBR = (n: number) => n.toLocaleString("pt-BR");

    if (prefersReducedMotion) {
      counters.forEach((el) => {
        const target = parseInt(el.dataset.target ?? "0", 10);
        el.textContent = formatBR(target);
      });
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const el = entry.target as HTMLElement;
            const target = parseInt(el.dataset.target ?? "0", 10);
            const duration = 1600;
            const start = performance.now();

            const tick = (now: number) => {
              const elapsed = now - start;
              const progress = Math.min(elapsed / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              const current = Math.floor(eased * target);
              el.textContent = formatBR(current);
              if (progress < 1) requestAnimationFrame(tick);
            };

            requestAnimationFrame(tick);
            observer.unobserve(el);
          });
        },
        { threshold: 0.3 }
      );

      counters.forEach((el) => observer.observe(el));
    }
  </script>

