---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Safras & Negócios | Mercado de café">
  <main class="min-h-screen flex items-center justify-center px-6">
    <section class="max-w-2xl text-center">
      <p
        class="text-sm font-medium uppercase tracking-[0.2em] text-brand mb-5"
      >
        Em construção
      </p>
      <h1
        class="text-5xl md:text-7xl font-bold text-ink leading-[1.05] mb-6"
      >
        Safras <span class="text-brand">&amp;</span> Negócios
      </h1>
      <p class="text-lg text-ink-muted">
        Nova versão do site em desenvolvimento.
      </p>
    </section>
  </main>
</BaseLayout>
