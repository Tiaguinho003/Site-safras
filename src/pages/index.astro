---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import lavouraDeCafe from "../assets/hero/lavoura-de-cafe.png";
import lavouraSunset from "../assets/about/lavoura-cafe-sunset.webp";

const stats = [
  { target: 10, suffix: "+", label: "Anos de história" },
  { target: 500, suffix: "", label: "Mil sacas negociadas por ano" },
  { target: 8, suffix: "", label: "Estados de atuação" },
];

const posts = [
  {
    category: "Notícias",
    date: "22 abr 2026",
    title: "Cotação do arábica renova máxima histórica com clima seco em Minas",
    excerpt:
      "A soma de geada fora de época e irregularidade nas chuvas pressiona o preço na ICE Futures desde janeiro.",
    href: "/noticias",
  },
  {
    category: "Blog",
    date: "15 abr 2026",
    title: "Como a classificação sensorial influencia o preço final da saca",
    excerpt:
      "Prova de xícara não é formalidade — é o detalhe que decide se uma saca vale bebida dura, mole ou riada.",
    href: "/blog",
  },
  {
    category: "Notícias",
    date: "08 abr 2026",
    title: "Safra 2026/27 projeta recorde em volumes exportáveis do Brasil",
    excerpt:
      "Levantamentos do Cecafé apontam colheita robusta, mesmo com adversidades pontuais no Cerrado Mineiro.",
    href: "/noticias",
  },
];

const services = [
  {
    number: "01",
    title: "Mercado e Negociação",
    iconSvg: `<path d="m11 17 2 2a1 1 0 1 0 3-3" /><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4" /><path d="m21 3 1 11h-2" /><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3" /><path d="M3 4h8" />`,
  },
  {
    number: "02",
    title: "Análise de Qualidade",
    iconSvg: `<path d="M17 8h1a4 4 0 1 1 0 8h-1" /><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z" /><line x1="6" x2="6" y1="2" y2="4" /><line x1="10" x2="10" y1="2" y2="4" /><line x1="14" x2="14" y1="2" y2="4" />`,
  },
  {
    number: "03",
    title: "Proteção Rural",
    iconSvg: `<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" /><path d="m9 12 2 2 4-4" />`,
  },
  {
    number: "04",
    title: "Suporte Logístico",
    iconSvg: `<path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2" /><path d="M15 18H9" /><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14" /><circle cx="17" cy="18" r="2" /><circle cx="7" cy="18" r="2" />`,
  },
];

const testimonials = [
  {
    quote:
      "Trabalho com a Safras desde 2021. O que mais valorizo é a clareza: o preço acertado é o preço pago, sem ajustes de última hora, sem chamada surpresa. No mercado de café, isso vale ouro.",
    author: "José Carlos Moreira",
    company: "Produtor — Cerrado Mineiro",
  },
  {
    quote:
      "Recebi os lotes na qualidade combinada, no prazo combinado, com a documentação em ordem. Em três operações seguidas. Numa atividade onde imprevisto é regra, isso é diferencial.",
    author: "Ricardo Tavares",
    company: "Tropical Trading",
  },
  {
    quote:
      "Conheço a Safras pela seriedade no relacionamento. Negociam com a paciência de quem entende a cooperativa por dentro — não jogam o produtor pra ver o que sobra. Parceria que se renova safra a safra.",
    author: "Luísa Andrade",
    company: "Coopcafé Vale",
  },
];
---

<BaseLayout title="Safras & Negócios | Corretora de café">
  <section
    class="relative min-h-[100svh] flex flex-col items-center overflow-hidden"
    aria-labelledby="hero-titulo"
  >
    <div
      class="absolute inset-0 -z-10 overflow-hidden"
      aria-hidden="true"
    >
      <Image
        src={lavouraDeCafe}
        alt=""
        widths={[1200, 1600, 2000]}
        sizes="100vw"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-black/25"></div>
      <div
        class="absolute inset-0"
        style="background: linear-gradient(180deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0) 28%, rgba(0,0,0,0) 60%, rgba(0,0,0,0.5) 100%);"
      >
      </div>
    </div>

    <div
      class="relative max-w-5xl w-full mx-auto px-6 md:px-10 pt-44 md:pt-56 text-center text-paper"
    >
      <span
        class="inline-block text-[11px] md:text-xs font-semibold uppercase tracking-[0.28em] text-paper/85 mb-6 md:mb-8"
      >
        Corretora de café
      </span>

      <h1
        id="hero-titulo"
        class="uppercase leading-[0.95] tracking-tight"
      >
        <span
          class="word-rotator hero-title-top block font-light text-paper text-5xl sm:text-6xl md:text-7xl lg:text-8xl xl:text-[7rem] tracking-[-0.01em]"
          aria-live="polite"
        >
          <span class="word-rotator__word" data-state="active">Tradição</span>
          <span class="word-rotator__word" data-state="queued" aria-hidden="true"
            >Confiança</span
          >
        </span>
        <span
          class="hero-title-divider block my-3 md:my-5 mx-auto"
          aria-hidden="true"
        ></span>
        <span
          class="hero-title-bottom block font-normal text-[#E8C07A] text-xl sm:text-2xl md:text-3xl lg:text-4xl xl:text-5xl"
        >
          no mercado de café
        </span>
      </h1>

      <p
        class="mt-8 md:mt-10 max-w-xl mx-auto text-base md:text-lg text-paper/90 leading-relaxed drop-shadow-[0_1px_12px_rgba(0,0,0,0.4)]"
      >
        Conectamos origem e mercado com a seriedade de quem entende de café.<br
          class="hidden md:inline"
        /> Há mais de 10 safras.
      </p>

    </div>

    <button
      type="button"
      data-scroll-next
      aria-label="Ir para a próxima seção"
      class="absolute bottom-8 md:bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-paper/70 hover:text-paper transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-paper/80 focus-visible:ring-offset-2 focus-visible:ring-offset-transparent rounded-full p-2"
    >
      <span
        class="relative block w-6 h-10 rounded-full border border-paper/60"
        aria-hidden="true"
      >
        <span
          class="scroll-mouse-dot absolute top-2 left-1/2 w-1 h-2 bg-paper/85 rounded-full -translate-x-1/2"
        ></span>
      </span>
    </button>
  </section>

  <section
    id="proximo"
    class="bg-paper border-t border-line scroll-mt-20 md:scroll-mt-28"
    aria-labelledby="servicos-titulo"
  >
    <div class="max-w-[100rem] mx-auto px-6 md:px-10 py-20 md:py-28 lg:py-32">
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 mb-14 md:mb-20 lg:mb-24"
      >
        <div>
          <span
            class="inline-block text-xs font-semibold uppercase tracking-[0.22em] text-brand mb-5"
          >
            [ Serviços ]
          </span>
          <h2
            id="servicos-titulo"
            class="text-4xl md:text-5xl lg:text-[3.5rem] xl:text-[4rem] font-semibold text-ink leading-[1.05] tracking-tight"
          >
            Soluções completas para o
            <span class="text-brand">mercado cafeeiro.</span>
          </h2>
        </div>

        <div class="lg:pt-3 max-w-xl">
          <p
            class="text-xl md:text-2xl lg:text-[1.625rem] text-ink-muted leading-[1.4]"
          >
            Da origem à comercialização, oferecemos
            <span class="text-ink font-medium">suporte estratégico</span>
            para produtores, compradores e empresas do mercado cafeeiro.
          </p>

          <hr class="mt-8 md:mt-10 border-t border-line" />

          <a
            href="/servicos"
            class="mt-8 md:mt-10 inline-flex items-center px-7 py-3 rounded-full border border-ink text-ink text-sm font-medium hover:bg-ink hover:text-paper transition-colors duration-300"
          >
            Ver todos os serviços
          </a>
        </div>
      </div>

      <div
        id="servicos-accordion"
        class="flex flex-col md:flex-row gap-4 md:gap-5 md:h-[560px] lg:h-[640px] xl:h-[680px]"
      >
        {
          services.map((service, idx) => (
            <article
              data-service-card
              data-active={idx === 0 ? "true" : "false"}
              class="group relative overflow-hidden rounded-2xl bg-paper-alt border border-dashed border-line cursor-pointer flex-1 md:flex-[1_1_0%] data-[active=true]:md:flex-[3_1_0%] data-[active=true]:border-solid data-[active=true]:border-line h-[300px] md:h-full transition-[flex,border-color] duration-500 ease-[cubic-bezier(0.29,0,0.2,1)] focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-4"
              tabindex="0"
              aria-label={`Serviço ${service.number}: ${service.title}`}
            >
              <span
                aria-hidden="true"
                class="absolute inset-0 flex items-center justify-center text-xs italic text-ink-muted/60 select-none"
              >
                Imagem em breve
              </span>

              <div
                aria-hidden="true"
                class="absolute inset-0 bg-paper/85 transition-opacity duration-[600ms] ease-[cubic-bezier(0.48,0,0.11,1)] group-data-[active=true]:opacity-0"
              />

              <div
                aria-hidden="true"
                class="absolute inset-0 opacity-0 transition-opacity duration-[600ms] ease-[cubic-bezier(0.48,0,0.11,1)] group-data-[active=true]:opacity-100"
                style="background: linear-gradient(180deg, rgba(20,19,17,0) 45%, rgba(20,19,17,0.85) 100%);"
              />

              <div class="relative h-full p-5 md:p-6 lg:p-7 flex flex-col justify-between">
                <div class="flex items-start justify-between gap-4">
                  <div
                    class="w-11 h-11 md:w-12 md:h-12 rounded-xl flex items-center justify-center bg-ink text-paper group-data-[active=true]:bg-brand transition-colors duration-500 ease-[cubic-bezier(0.48,0,0.11,1)] shrink-0"
                    aria-hidden="true"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="22"
                      height="22"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      set:html={service.iconSvg}
                    />
                  </div>
                  <span
                    class="text-4xl md:text-5xl lg:text-6xl font-semibold text-brand leading-none tracking-tight opacity-0 group-data-[active=true]:opacity-100 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] delay-[400ms]"
                    aria-hidden="true"
                  >
                    {service.number}
                  </span>
                </div>

                <div>
                  <h3 class="sr-only">{service.title}</h3>

                  <div class="grid" aria-hidden="true">
                    <span
                      class="col-start-1 row-start-1 self-end text-base md:text-lg font-semibold text-ink leading-[1.2] tracking-tight line-clamp-2 transition-opacity duration-[300ms] ease-[cubic-bezier(0.48,0,0.11,1)] group-data-[active=true]:opacity-0"
                    >
                      {service.title}
                    </span>
                    <span
                      class="col-start-1 row-start-1 self-end text-2xl md:text-3xl lg:text-[2.5rem] font-semibold text-paper leading-[1.1] tracking-tight line-clamp-2 opacity-0 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] delay-[300ms] group-data-[active=true]:opacity-100"
                    >
                      {service.title}
                    </span>
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <p class="mt-10 text-xs italic text-ink-muted/70">
        ⚠ Imagens dos cards em placeholder — substituir por fotos reais antes
        de publicar.
      </p>
    </div>
  </section>

  <section
    class="bg-paper border-t border-line"
    aria-labelledby="quem-somos-titulo"
  >
    <div class="max-w-[100rem] mx-auto px-6 md:px-10 py-14 md:py-20 lg:py-24">
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start"
      >
        <div class="order-2 lg:order-1 max-w-2xl mx-auto lg:mx-0 lg:ml-32">
          <h2
            id="quem-somos-titulo"
            class="text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-light text-ink leading-[1.1] tracking-tight whitespace-nowrap"
          >
            Conectamos o Café<br />
            a <span class="text-brand font-bold">Grandes Oportunidades</span>,<br />
            da Origem ao Mercado.
          </h2>

          <a
            href="/quem-somos"
            class="mt-10 md:mt-12 inline-flex items-center px-8 py-4 rounded-full bg-brand text-paper text-base font-semibold hover:bg-brand-dark transition-colors duration-300"
          >
            Conheça nossa história
          </a>
        </div>

        <div class="order-1 lg:order-2 w-full max-w-md mx-auto lg:mx-0 lg:ml-auto lg:mr-12">
          <div
            class="relative aspect-square rounded-xl bg-paper-alt border border-dashed border-line overflow-hidden flex items-center justify-center shadow-[0_30px_60px_-30px_rgba(20,19,17,0.2)]"
            role="img"
            aria-label="Imagem ilustrativa de Quem Somos — em breve"
          >
            <span class="text-xs text-ink-muted/70 italic">
              Imagem em breve
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section
    class="bg-paper-alt border-t border-line"
    aria-label="Números da Safras"
  >
    <div class="max-w-[100rem] mx-auto px-6 md:px-10 py-16 md:py-20 lg:py-24">
      <div class="stat-container relative">
        <div class="stat-container__overlay" aria-hidden="true"></div>

        <div class="stat-col stat-col--1">
          <span class="stat-divider stat-divider--right" aria-hidden="true"></span>
          <div>
            <div class="flex items-baseline tabular-nums">
              <span
                data-counter
                data-target="10"
                class="text-7xl md:text-8xl lg:text-[7rem] xl:text-[8rem] font-light text-paper leading-none tracking-tight"
                >0</span>
              <span
                class="text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-light text-paper leading-none tracking-tight ml-1"
                aria-hidden="true"
                >+</span>
            </div>
            <p class="mt-2 md:mt-3 text-sm md:text-base text-paper font-medium tracking-wide">
              Anos de história
            </p>
          </div>
        </div>

        <div class="stat-col stat-col--2">
          <span class="stat-divider stat-divider--right" aria-hidden="true"></span>
          <div class="text-center">
            <span
              data-counter
              data-target="500"
              class="block text-7xl md:text-8xl lg:text-[7rem] xl:text-[8rem] font-light text-paper leading-none tracking-tight tabular-nums"
              >0</span>
            <p class="mt-2 md:mt-3 text-sm md:text-base text-paper font-medium tracking-wide">
              Mil sacas negociadas por ano
            </p>
          </div>
        </div>

        <div class="stat-col stat-col--3">
          <div class="text-right">
            <span
              data-counter
              data-target="8"
              class="block text-7xl md:text-8xl lg:text-[7rem] xl:text-[8rem] font-light text-paper leading-none tracking-tight tabular-nums"
              >0</span>
            <p class="mt-2 md:mt-3 text-sm md:text-base text-paper font-medium tracking-wide">
              Estados de atuação
            </p>
          </div>
        </div>
      </div>
    </div>

    <style define:vars={{ statBg: `url(${lavouraSunset.src})` }}>
      .stat-container {
        position: relative;
        display: flex;
        min-height: 460px;
        background-image: var(--statBg);
        background-position: center center;
        background-repeat: no-repeat;
        background-size: cover;
      }
      .stat-container__overlay {
        position: absolute;
        inset: 0;
        background-color: rgba(2, 3, 8, 0.32);
        pointer-events: none;
        z-index: 1;
      }
      .stat-col {
        position: relative;
        z-index: 2;
        flex: 1 1 0%;
        display: flex;
        padding: 25px;
        min-width: 0;
      }
      .stat-col--1 { justify-content: flex-start; align-items: flex-end; }
      .stat-col--2 { justify-content: center; align-items: center; }
      .stat-col--3 { justify-content: flex-end; align-items: flex-start; }

      .stat-divider {
        position: absolute;
        top: 0;
        right: -6px;
        width: 12px;
        height: 100%;
        background-color: #f6f6f4;
        z-index: 3;
        pointer-events: none;
      }

      @media (min-width: 768px) {
        .stat-container {
          min-height: 615px;
          background-attachment: fixed;
          clip-path: polygon(
            2.5% 0,
            100% 0,
            100% 95%,
            97.5% 100%,
            0 100%,
            0 5.5%
          );
        }
        .stat-col {
          padding: 32px;
        }
      }

      @media (min-width: 1024px) {
        .stat-container {
          min-height: 680px;
        }
        .stat-col {
          padding: 48px;
        }
      }

      @media (max-width: 767px) {
        .stat-container {
          flex-direction: column;
          min-height: auto;
          border-radius: 16px;
          overflow: hidden;
        }
        .stat-col {
          min-height: 240px;
          padding: 28px;
        }
        .stat-divider {
          right: 0;
          left: 0;
          top: auto;
          bottom: -6px;
          width: 100%;
          height: 12px;
        }
      }
    </style>
  </section>

  <section
    class="bg-paper border-t border-line"
    aria-labelledby="depoimentos-titulo"
  >
    <h2 id="depoimentos-titulo" class="sr-only">Depoimentos</h2>
    <div
      class="max-w-[100rem] mx-auto px-6 md:px-10 py-24 md:py-32 lg:py-36"
    >
      <div class="relative max-w-4xl mx-auto">
        <div
          aria-hidden="true"
          class="testimonial-quotes text-center text-ink leading-none mb-10 md:mb-14 select-none"
        >
          ”
        </div>

        <div class="relative">
          <button
            type="button"
            data-testimonial-prev
            aria-label="Depoimento anterior"
            class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-1 md:-translate-x-2 p-2 text-ink-muted hover:text-ink transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand rounded-full"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m15 18-6-6 6-6" />
            </svg>
          </button>

          <div class="testimonial-stack grid px-12 md:px-20 lg:px-24">
            {
              testimonials.map((t, idx) => (
                <article
                  data-testimonial-slide
                  data-active={idx === 0 ? "true" : "false"}
                  class="testimonial-slide text-center"
                  aria-hidden={idx === 0 ? "false" : "true"}
                >
                  <blockquote>
                    <p class="text-xl md:text-2xl lg:text-[1.75rem] text-ink leading-[1.45] font-medium tracking-tight">
                      “{t.quote}”
                    </p>
                  </blockquote>

                  <div
                    class="mt-12 md:mt-14 flex flex-col items-center"
                    aria-hidden="true"
                  >
                    <span class="block w-px h-5 bg-ink/30" />
                    <span class="block w-40 md:w-56 h-px bg-ink/30" />
                  </div>

                  <footer class="mt-6 md:mt-7 text-base md:text-lg">
                    <span class="text-ink font-medium">{t.author},</span>{" "}
                    <span class="text-ink-muted">{t.company}</span>
                  </footer>
                </article>
              ))
            }
          </div>

          <button
            type="button"
            data-testimonial-next
            aria-label="Próximo depoimento"
            class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1 md:translate-x-2 p-2 text-ink-muted hover:text-ink transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand rounded-full"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m9 18 6-6-6-6" />
            </svg>
          </button>
        </div>
      </div>

      <p class="mt-16 text-xs italic text-ink-muted/70 text-center">
        ⚠ Depoimentos placeholder — substituir por reais antes de publicar.
      </p>
    </div>

    <script>
      const slides = document.querySelectorAll<HTMLElement>(
        "[data-testimonial-slide]"
      );
      const prevBtn = document.querySelector<HTMLButtonElement>(
        "[data-testimonial-prev]"
      );
      const nextBtn = document.querySelector<HTMLButtonElement>(
        "[data-testimonial-next]"
      );

      if (slides.length > 0) {
        let activeIdx = 0;
        const total = slides.length;

        const goTo = (idx: number) => {
          activeIdx = (idx + total) % total;
          slides.forEach((slide, i) => {
            const isActive = i === activeIdx;
            slide.dataset.active = isActive ? "true" : "false";
            slide.setAttribute("aria-hidden", isActive ? "false" : "true");
          });
        };

        prevBtn?.addEventListener("click", () => goTo(activeIdx - 1));
        nextBtn?.addEventListener("click", () => goTo(activeIdx + 1));
      }
    </script>

    <style>
      .testimonial-quotes {
        font-size: clamp(4.5rem, 9vw, 8rem);
        font-weight: 700;
        font-feature-settings: "ss01";
