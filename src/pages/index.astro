  <script>
    const cards = document.querySelectorAll<HTMLElement>("[data-service-card]");

    const activate = (target: HTMLElement) => {
      cards.forEach((card) => {
        card.dataset.active = card === target ? "true" : "false";
      });
    };

    cards.forEach((card) => {
      card.addEventListener("mouseenter", () => activate(card));
      card.addEventListener("focus", () => activate(card));
    });
  </script>

  <script>
    const counters = document.querySelectorAll<HTMLElement>("[data-counter]");
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    const formatBR = (n: number) => n.toLocaleString("pt-BR");

    if (prefersReducedMotion) {
      counters.forEach((el) => {
        const target = parseInt(el.dataset.target ?? "0", 10);
        el.textContent = formatBR(target);
      });
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const el = entry.target as HTMLElement;
            const target = parseInt(el.dataset.target ?? "0", 10);
            const duration = 1600;
            const start = performance.now();

            const tick = (now: number) => {
              const elapsed = now - start;
              const progress = Math.min(elapsed / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              const current = Math.floor(eased * target);
              el.textContent = formatBR(current);
              if (progress < 1) requestAnimationFrame(tick);
            };

            requestAnimationFrame(tick);
            observer.unobserve(el);
          });
        },
        { threshold: 0.3 }
      );

      counters.forEach((el) => observer.observe(el));
    }
  </script>

  <style>
    .word-rotator {
      display: inline-grid;
      grid-template-areas: "stack";
      vertical-align: baseline;
      overflow: hidden;
      padding-top: 0.16em;
      padding-bottom: 0.06em;
    }
    .word-rotator__word {
      grid-area: stack;
      transition:
        transform 800ms cubic-bezier(0.65, 0, 0.35, 1),
        opacity 600ms cubic-bezier(0.65, 0, 0.35, 1);
      will-change: transform, opacity;
    }
    .word-rotator__word[data-state="active"] {
      transform: translateY(0);
      opacity: 1;
    }
    .word-rotator__word[data-state="exit"] {
      transform: translateY(100%);
      opacity: 0;
    }
    .word-rotator__word[data-state="queued"] {
      transform: translateY(100%);
      opacity: 0;
    }
    @media (prefers-reduced-motion: reduce) {
      .word-rotator__word {
        transition: none;
      }
    }
    .word-rotator-divider {
      height: 1px;
      max-width: 38%;
      background: linear-gradient(
        to right,
        rgba(255, 255, 255, 0) 0%,
        rgba(255, 255, 255, 0.85) 40%,
        rgba(255, 255, 255, 0.85) 60%,
        rgba(255, 255, 255, 0) 100%
      );
    }

    .partners-marquee-mask {
      mask-image: linear-gradient(
        to right,
        transparent 0,
        black 6%,
        black 94%,
        transparent 100%
      );
      -webkit-mask-image: linear-gradient(
        to right,
        transparent 0,
        black 6%,
        black 94%,
        transparent 100%
      );
    }
    .partners-marquee-track {
      animation: partners-marquee 28s linear infinite;
    }
    .scroll-down__icon {
      animation: scroll-bounce 1.8s ease-in-out infinite;
    }
    @keyframes scroll-bounce {
      0%,
      100% {
        transform: translateY(-2px);
      }
      50% {
        transform: translateY(4px);
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .scroll-down__icon {
        animation: none;
      }
    }
    .partners-marquee-mask:hover .partners-marquee-track {
      animation-play-state: paused;
    }
    @keyframes partners-marquee {
      from {
        transform: translateX(0);
      }
      to {
        transform: translateX(-50%);
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .partners-marquee-track {
        animation: none;
      }
    }
  </style>

  <script>
    const scrollNextBtn = document.querySelector<HTMLButtonElement>(
