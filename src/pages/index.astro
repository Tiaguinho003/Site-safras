---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactSection from "../components/sections/ContactSection.astro";
import cafeCerejaMao from "../assets/hero/cafe-cereja-mao.png";
import saoSebastiaoParaiso from "../assets/about/sao-sebastiao-paraiso.png";
import lavouraCafePaisagem from "../assets/about/lavoura-cafe-paisagem.png";
import analiseQualidadeImg from "../assets/services/analise-qualidade.png";
import mercadoNegociacaoImg from "../assets/services/mercado-negociacao.png";
import suporteLogisticoImg from "../assets/services/suporte-logistico.png";

const statsCards = [
  {
    type: "city" as const,
    lines: ["São", "Sebastião", "do Paraíso"],
    label: "Sediado em",
    position: "top" as const,
  },
  {
    type: "counter" as const,
    target: 10,
    suffix: "+",
    label: "Anos de história",
    position: "bottom" as const,
  },
];

const differentials = [
  {
    title: "Nossa história",
    description:
      "Fundada em outubro de 2015, a Safras & Negócios iniciou sua trajetória no mercado cafeeiro com foco na intermediação de operações comerciais. Ao longo dos anos se consolidando como uma das principais corretoras da região, enxergando grandes oportunidades para o café mineiro.",
    iconSvg: `<path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" /><path d="M3 3v5h5" /><path d="M12 7v5l4 2" />`,
  },
  {
    title: "Nossa missão",
    description:
      "Aproximar o café brasileiro dos mercados que reconhecem seu valor, construindo relações comerciais baseadas em confiança, respeito e conhecimento. Da fazenda à exportação, buscamos valorizar cada etapa que leva o café da nossa origem para o mundo.",
    iconSvg: `<circle cx="12" cy="12" r="10" /><circle cx="12" cy="12" r="6" /><circle cx="12" cy="12" r="2" />`,
  },
  {
    title: "Nossos valores",
    description:
      "Nossos valores estão presentes em cada etapa da comercialização do café: transparência nas negociações, respeito às relações construídas, responsabilidade na condução dos processos, compromisso com a qualidade e confiança como base de cada parceria.",
    iconSvg: `<circle cx="12" cy="12" r="10" /><path d="m16.24 7.76-1.804 5.411a2 2 0 0 1-1.265 1.265L7.76 16.24l1.804-5.411a2 2 0 0 1 1.265-1.265z" />`,
  },
];

const servicosTituloPalavras = [
  { texto: "Soluções", brand: false },
  { texto: "completas", brand: false },
  { texto: "para", brand: false },
  { texto: "o", brand: false },
  { texto: "mercado", brand: true },
  { texto: "cafeeiro.", brand: true },
];

const services = [
  {
    number: "01",
    title: "Mercado e Negociação",
    iconSvg: `<path d="m11 17 2 2a1 1 0 1 0 3-3" /><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4" /><path d="m21 3 1 11h-2" /><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3" /><path d="M3 4h8" />`,
    image: mercadoNegociacaoImg,
    imageAlt:
      "Consultor da Safras & Negócios com prancheta orientando produtor de café em lavoura nas montanhas",
    imagePosition: "50% 35%",
    description:
      "Intermediamos negócios no mercado de café com análise de mercado, consultoria comercial e acompanhamento completo da negociação.",
    strips: [
      "Consultoria comercial",
      "Mercado físico",
      "Mercado futuro",
      "Conexão\nProdução/Exportação",
      "CPR financeira",
    ],
  },
  {
    number: "02",
    title: "Análise de Qualidade",
    iconSvg: `<path d="M17 8h1a4 4 0 1 1 0 8h-1" /><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z" /><line x1="6" x2="6" y1="2" y2="4" /><line x1="10" x2="10" y1="2" y2="4" /><line x1="14" x2="14" y1="2" y2="4" />`,
    image: analiseQualidadeImg,
    imageAlt: "Grãos de café verde sobre tapete preto Safras & Negócios, ao lado de peneira de classificação",
    imagePosition: "30% 25%",
    description:
      "Avaliamos cada amostra por meio da classificação, prova sensorial e análise de umidade, oferecendo informações técnicas para uma negociação mais segura.",
    strips: ["Classificação de grãos", "Análise sensorial", "Análise de umidade"],
  },
  {
    number: "03",
    title: "Suporte Logístico",
    iconSvg: `<path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2" /><path d="M15 18H9" /><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14" /><circle cx="17" cy="18" r="2" /><circle cx="7" cy="18" r="2" />`,
    image: suporteLogisticoImg,
    imageAlt:
      "Equipe da Safras & Negócios supervisionando carregamento de sacas de café em caminhão com empilhadeira",
    imagePosition: "55% 50%",
    description:
      "Apoiamos a etapa logística do café com agendamentos de embarque e desembarque, emissão de notas fiscais de remessa e acompanhamento completo do processo.",
    strips: ["Embarque", "Desembarque", "Suporte Pós Venda"],
  },
];

const testimonials = [
  {
    quote:
      "Trabalho com a Safras desde 2021. O que mais valorizo é a clareza: o preço acertado é o preço pago, sem ajustes de última hora, sem chamada surpresa. No mercado de café, isso vale ouro.",
    author: "José Carlos Moreira",
    company: "Produtor — Cerrado Mineiro",
  },
  {
    quote:
      "Recebi os lotes na qualidade combinada, no prazo combinado, com a documentação em ordem. Em três operações seguidas. Numa atividade onde imprevisto é regra, isso é diferencial.",
    author: "Ricardo Tavares",
    company: "Tropical Trading",
  },
  {
    quote:
      "Conheço a Safras pela seriedade no relacionamento. Negociam com a paciência de quem entende a cooperativa por dentro — não jogam o produtor pra ver o que sobra. Parceria que se renova safra a safra.",
    author: "Luísa Andrade",
    company: "Coopcafé Vale",
  },
];
---

<BaseLayout title="Safras & Negócios | Corretora de café">
  <section
    id="hero"
    class="relative min-h-[97svh] flex flex-col items-center overflow-hidden"
    aria-labelledby="hero-titulo"
  >
    <div
      class="absolute inset-0 -z-10 overflow-hidden"
      aria-hidden="true"
    >
      <Image
        src={cafeCerejaMao}
        alt=""
        widths={[1200, 1600, 2000]}
        sizes="100vw"
        class="w-full h-full object-cover"
        style="object-position: 88% center;"
        loading="eager"
      />
      <div class="absolute inset-0 bg-black/28"></div>
      <div
        class="absolute inset-0"
        style="background: linear-gradient(90deg, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.55) 20%, rgba(0,0,0,0.28) 45%, rgba(0,0,0,0) 70%), linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0) 65%, rgba(0,0,0,0.45) 100%);"
      >
      </div>
    </div>

    <div
      class="relative max-w-[100rem] w-full mx-auto px-6 md:px-10 pt-40 md:pt-52 text-paper"
    >
      <div class="text-center">
        <span
          class="inline-block text-[11px] md:text-xs font-semibold uppercase tracking-[0.28em] text-paper/85 mb-6 md:mb-8"
        >
          [ Corretora de café ]
        </span>
      </div>

      <h1
        id="hero-titulo"
        class="uppercase md:normal-case leading-[0.95] mx-auto mt-0 md:mt-2 text-center font-light md:font-extralight text-paper text-4xl sm:text-5xl md:text-5xl lg:text-[64px] xl:text-[80px] 2xl:text-[150px] tracking-[-0.01em] md:tracking-[-0.03em]"
      >
        <span class="block">
          <span class="word-rotator uppercase font-extralight text-5xl sm:text-6xl md:text-6xl lg:text-[80px] xl:text-[150px] 2xl:text-[120px]" aria-live="polite">
            <span class="word-rotator__word" data-state="active">Tradição</span>
            <span class="word-rotator__word" data-state="queued" aria-hidden="true"
              >Confiança</span
            >
          </span>
        </span>
        <span class="block text-[#e8fb85] font-medium text-3xl sm:text-4xl md:text-4xl lg:text-[48px] xl:text-[64px] 2xl:text-[80px]">no mercado cafeeiro</span>
      </h1>

    </div>

    <div class="absolute bottom-12 md:bottom-2 left-1/2 -translate-x-1/2 w-11/12 max-w-4xl">
      <svg
        viewBox="0 0 1000 480"
        preserveAspectRatio="xMidYMid meet"
        class="w-full h-auto block"
        aria-hidden="true"
        style="filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.35));"
      >
        <path
          d="M 20 460 Q 500 5 980 460 Q 500 9 20 460 Z"
          fill="rgba(255, 255, 255, 0.95)"
        />
      </svg>
      <a
        href="#servicos"
        data-radial-button
        class="group absolute left-1/2 top-[48%] -translate-x-1/2 -translate-y-1/2 inline-flex items-center gap-1.5 bg-paper border-2 border-transparent hover:border-paper text-ink hover:text-paper text-sm md:text-base font-medium px-5 py-2.5 rounded-full overflow-hidden whitespace-nowrap shadow-lg transition-colors duration-[600ms]"
      >
        <span class="relative z-10">Explorar Serviços</span>
        <span
          aria-hidden="true"
          class="relative z-10 transition-transform duration-[600ms] group-hover:translate-x-1"
        >→</span>
        <span
          aria-hidden="true"
          data-radial-fill
          style="left: 50%; top: 50%; transition: width 800ms ease-in-out;"
          class="absolute z-0 block aspect-square w-0 -translate-x-1/2 -translate-y-1/2 rounded-full bg-brand group-hover:w-[225%]"
        ></span>
      </a>
    </div>

    <button
      type="button"
      data-scroll-next
      aria-label="Ir para a próxima seção"
      class="absolute bottom-8 md:bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-paper/70 hover:text-paper transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-paper/80 focus-visible:ring-offset-2 focus-visible:ring-offset-transparent rounded-full p-2"
    >
      <span
        class="relative block w-6 h-10 rounded-full border border-paper/60"
        aria-hidden="true"
      >
        <span
          class="scroll-mouse-dot absolute top-2 inset-x-0 mx-auto w-1 h-2 bg-paper/85 rounded-full"
        ></span>
      </span>
    </button>
  </section>

  <section
    id="servicos"
    class="bg-paper scroll-mt-20 md:scroll-mt-28"
    aria-labelledby="servicos-titulo"
  >
    <div class="max-w-[88rem] mx-auto px-6 md:px-10 py-20 md:py-28 lg:py-32 pb-14 md:pb-20 lg:pb-24">
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-6 mb-20 md:mb-28 lg:mb-32"
      >
        <div>
          <div class="flex items-start gap-6 md:gap-10 lg:gap-14">
            <span
              class="inline-block text-xs font-semibold uppercase tracking-[0.22em] text-brand whitespace-nowrap shrink-0 mt-2 md:mt-3 lg:-mt-8"
            >
              [ Serviços ]
            </span>
            <h2
              id="servicos-titulo"
              data-reveal="split-text"
              class="split-text text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-medium text-ink leading-[1.05] tracking-[-0.03em] lg:-mt-8"
            >
              <span class="block">
                <span class="split-text-word" style="transition-delay: 0ms;">Soluções</span>
              </span>
              <span class="block">
                <span class="split-text-word" style="transition-delay: 80ms;">completas</span>
                <span class="split-text-word" style="transition-delay: 160ms;">para</span>
              </span>
              <span class="block">
                <span class="split-text-word align-top" style="transition-delay: 240ms;">o</span>
                <span class="split-text-word align-top" style="transition-delay: 320ms;">seu</span>
                <span class="split-text-word text-brand text-3xl md:text-4xl lg:text-5xl xl:text-6xl relative" style="transition-delay: 400ms; top: -0.1em; left: 0.05em;">café</span>
              </span>
            </h2>
          </div>
        </div>

        <div class="lg:-mt-8 max-w-xl fade-in-up" data-reveal="fade-in-up">
          <p
            class="text-xl md:text-2xl lg:text-3xl text-ink/50 leading-[1.33]"
          >
            Da origem à comercialização, oferecemos
            <span class="text-brand font-medium">serviço estratégico</span>
            para produtores, compradores, empresas e exportadoras do mercado.
          </p>
          <div
            aria-hidden="true"
            class="mt-8 md:mt-10 h-px lg:h-0.5 w-full bg-ink opacity-20"
          ></div>
        </div>
      </div>

      <div
        id="servicos-accordion"
        class="flex flex-col md:flex-row gap-5 md:gap-6 md:h-[386px]"
      >
        {
          services.map((service, idx) => (
            <article
              data-service-card
              data-active={idx === 0 ? "true" : "false"}
              class="group relative overflow-hidden rounded-2xl bg-paper-alt border border-dashed border-line cursor-pointer flex-1 md:flex-[1_1_0%] data-[active=true]:md:flex-[3_1_0%] data-[active=true]:border-solid data-[active=true]:border-line h-[300px] md:h-full transition-[flex,border-color] duration-500 ease-[cubic-bezier(0.29,0,0.2,1)] focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-4"
              tabindex="0"
              aria-label={`Serviço ${service.number}: ${service.title}`}
            >
              {service.image ? (
                <Image
                  src={service.image}
                  alt={service.imageAlt ?? ""}
                  widths={[600, 900, 1200]}
                  sizes="(min-width: 1024px) 40vw, (min-width: 768px) 50vw, 100vw"
                  class="absolute inset-0 w-full h-full object-cover"
                  style={`object-position: ${service.imagePosition ?? "center"};`}
                  loading="lazy"
                />
              ) : (
                <span
                  aria-hidden="true"
                  class="absolute inset-0 flex items-center justify-center text-xs italic text-ink-muted/60 select-none"
                >
                  Imagem em breve
                </span>
              )}

              <div
                aria-hidden="true"
                class="absolute inset-0 bg-paper-alt/70 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] group-data-[active=true]:opacity-0"
              />

              <div
                aria-hidden="true"
                class="absolute inset-0 opacity-0 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] group-data-[active=true]:opacity-100"
                style="background: linear-gradient(180deg, rgba(0,0,0,0) 22%, rgba(0,0,0,0.4) 97%);"
              />

              <div class="relative h-full p-4 md:p-6 flex flex-col justify-between">
                <div class="flex items-start justify-between gap-4">
                  <div
                    class="w-11 h-11 md:w-12 md:h-12 rounded-xl flex items-center justify-center bg-ink text-[#e8fb85] group-data-[active=true]:bg-[#e8fb85] group-data-[active=true]:text-ink transition-colors duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] shrink-0"
                    aria-hidden="true"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="22"
                      height="22"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      set:html={service.iconSvg}
                    />
                  </div>
                </div>

                <div>
                  <h3 class="sr-only">{service.title}</h3>

                  <div class="grid" aria-hidden="true">
                    <span
                      class="col-start-1 row-start-1 self-end text-[26px] md:text-[28px] lg:text-[30px] font-medium text-ink leading-[1.2] tracking-[-0.02em] line-clamp-2 transition-opacity duration-[300ms] ease-[cubic-bezier(0.48,0,0.11,1)] group-data-[active=true]:opacity-0"
                    >
                      {service.title}
                    </span>
                    <span
                      class="col-start-1 row-start-1 self-end text-[35px] md:text-[40px] lg:text-[48px] font-medium text-paper leading-[1.08] tracking-[-0.05em] line-clamp-2 opacity-0 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] delay-[300ms] group-data-[active=true]:opacity-100"
                    >
                      {service.title}
                    </span>
                  </div>

                  <div
                    aria-hidden="true"
                    class="mt-4 md:mt-6 h-1 w-[calc(100%-5px)] rounded bg-white/50 backdrop-blur-lg overflow-hidden opacity-0 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] group-data-[active=true]:opacity-100"
                  >
                    <div
                      class="h-full w-0 bg-white rounded transition-[width] duration-[650ms] ease-[cubic-bezier(0.48,0,0.11,1)] delay-[550ms] group-data-[active=true]:w-full"
                    ></div>
                  </div>
                </div>
              </div>

              <div
                aria-hidden="true"
                class="absolute inset-y-0 right-0 w-[200px] bg-black/60 origin-right scale-x-0 transition-transform duration-[150ms] ease-out group-data-[active=true]:scale-x-100 group-data-[active=true]:duration-[900ms] group-data-[active=true]:ease-[cubic-bezier(0.22,1,0.36,1)] group-data-[active=true]:delay-[500ms]"
              ></div>

              {service.description && (
                <div
                  class="absolute inset-y-0 right-0 w-[200px] p-5 md:p-6 flex items-center pointer-events-none"
                >
                  <p class="text-paper/95 text-[14px] leading-[1.5] font-normal tracking-[0.005em]">
                    {service.description.split(" ").flatMap((word, i) => [
                      <span
                        class="inline-block opacity-0 translate-y-1 blur-[2px] group-data-[active=true]:opacity-100 group-data-[active=true]:translate-y-0 group-data-[active=true]:blur-none group-data-[active=true]:transition-[opacity,transform,filter] group-data-[active=true]:duration-[550ms] group-data-[active=true]:ease-[cubic-bezier(0.22,1,0.36,1)] group-data-[active=true]:[transition-delay:var(--word-delay)]"
                        style={`--word-delay: ${900 + i * 32}ms;`}
                      >
                        {word}
                      </span>,
                      " ",
                    ])}
                  </p>
                </div>
              )}
            </article>
          ))
        }
      </div>

    </div>
  </section>

  <section
    id="quem-somos"
    class="bg-paper scroll-mt-20 md:scroll-mt-28"
    aria-labelledby="quem-somos-titulo"
  >
    <div class="max-w-[88rem] mx-auto px-6 md:px-10 pt-14 md:pt-20 lg:pt-24">

      {/* ===== Row 1: Header — mesmo padrão da seção Serviços ===== */}
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-6 mb-10 md:mb-14 lg:mb-20"
      >
        <div>
          <div class="flex items-start gap-6 md:gap-10 lg:gap-14">
            {/* Coluna interna: tag em cima, grão logo abaixo */}
            <div class="flex flex-col items-start shrink-0 gap-6">
              <span
                class="inline-block text-xs font-semibold uppercase tracking-[0.22em] text-brand whitespace-nowrap shrink-0 mt-2 md:mt-3 lg:mt-12"
              >
                [ Sobre nós ]
              </span>

              <div
                class="coffee-bean-float relative w-[100px] h-[100px] md:w-[120px] md:h-[120px] text-brand"
                aria-hidden="true"
              >
                <div class="coffee-bean-tilt w-full h-full">
                  <svg
                    viewBox="0 0 160 160"
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-full h-full"
                  >
                    <g transform="rotate(8 80 80)">
                      <ellipse cx="80" cy="80" rx="36" ry="52" stroke-width="2.5" />
                      <path d="M 80 30 C 98 48, 98 112, 80 130" stroke-width="2" />
                      <path d="M 80 33 C 93 55, 73 105, 80 127" stroke-width="1.8" />
                      <path d="M 80 33 C 87 55, 67 105, 80 127" stroke-width="1.8" />
                    </g>
                  </svg>
                </div>
              </div>
            </div>

            <h2
              id="quem-somos-titulo"
              data-reveal="split-text"
              class="split-text text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-medium text-ink leading-[1.05] tracking-[-0.03em] lg:mt-12"
            >
              <span class="block">
                <span class="split-text-word" style="transition-delay: 0ms;">Na</span>
                <span class="split-text-word text-brand" style="transition-delay: 80ms;">Safras,</span>
              </span>
              <span class="block">
                <span class="split-text-word" style="transition-delay: 160ms;">conectamos</span>
                <span class="split-text-word" style="transition-delay: 240ms;">a</span>
                <span class="split-text-word" style="transition-delay: 320ms;">origem</span>
              </span>
              <span class="block">
                <span class="split-text-word" style="transition-delay: 400ms;">ao</span>
                <span class="split-text-word" style="transition-delay: 480ms;">mercado.</span>
              </span>
            </h2>
          </div>
        </div>

        <div class="lg:mt-12 max-w-xl fade-in-up" data-reveal="fade-in-up">
          <p
            class="text-xl md:text-2xl lg:text-3xl text-ink/50 leading-[1.33]"
          >
            Com mais de 10 anos no mercado, oferecemos consultoria e
            intermediação de café com a transparência e seriedade que
            produtores e compradores esperam.
          </p>
          <div
            aria-hidden="true"
            class="mt-8 md:mt-10 h-px lg:h-0.5 w-full bg-ink opacity-20"
          ></div>
        </div>
      </div>

      {/* ===== Row 2: Stats — cidade (com imagem) + +10 (verde sólido) ===== */}
      <div class="grid grid-cols-1 md:grid-cols-[2.64fr_1fr] gap-3 md:gap-4 lg:gap-5">
        {
          statsCards.map((stat, i) => {
            const clip =
              i === 0
                ? "polygon(28px 0, 100% 0, 100% 100%, 0 100%, 0 28px)"
                : i === statsCards.length - 1
                  ? "polygon(0 0, 100% 0, 100% calc(100% - 28px), calc(100% - 28px) 100%, 0 100%)"
                  : null;
            const isCity = stat.type === "city";
            return (
              <div
