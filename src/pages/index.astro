---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import cafezalAereo from "../assets/hero/cafezal-aereo.jpg";
import provaDeXicara from "../assets/hero/prova-de-xicara.jpg";

const services = [
  {
    number: "01",
    title: "Corretagem de café",
    description:
      "Intermediamos a negociação entre produtor e comprador com neutralidade e leitura de mercado, assegurando preço justo, contrato claro e pagamento em dia.",
    iconSvg: `<path d="m11 17 2 2a1 1 0 1 0 3-3" /><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4" /><path d="m21 3 1 11h-2" /><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3" /><path d="M3 4h8" />`,
  },
  {
    number: "02",
    title: "Assessoria de mercado",
    description:
      "Inteligência de preços, análise de safra e acompanhamento macroeconômico para orientar decisões de venda, hedge e planejamento de longo prazo.",
    iconSvg: `<polyline points="22 7 13.5 15.5 8.5 10.5 2 17" /><polyline points="16 7 22 7 22 13" />`,
  },
  {
    number: "03",
    title: "Classificação e qualidade",
    description:
      "Prova de xícara e classificação sensorial executadas por profissionais experientes, lote por lote — agregando valor e garantindo padrão na entrega.",
    iconSvg: `<path d="M17 8h1a4 4 0 1 1 0 8h-1" /><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z" /><line x1="6" x2="6" y1="2" y2="4" /><line x1="10" x2="10" y1="2" y2="4" /><line x1="14" x2="14" y1="2" y2="4" />`,
  },
];
---

<BaseLayout title="Safras & Negócios | Corretora de café">
  <section
    class="relative overflow-hidden bg-paper"
    aria-labelledby="hero-titulo"
  >
    <div
      class="max-w-7xl mx-auto px-6 md:px-10 pt-14 md:pt-20 lg:pt-24 pb-28 md:pb-40 lg:pb-48"
    >
      <div
        class="grid grid-cols-1 lg:grid-cols-[1fr_1.1fr] gap-12 lg:gap-16 items-start"
      >
        <div class="max-w-xl lg:pt-6">
          <span
            class="inline-block text-xs font-semibold uppercase tracking-[0.22em] text-brand mb-6"
          >
            [ Corretora de café ]
          </span>

          <h1
            id="hero-titulo"
            class="text-4xl md:text-5xl lg:text-[3.5rem] font-semibold text-ink leading-[1.08] tracking-tight"
          >
            Tradição e confiança
            <span class="text-brand">no mercado do café.</span>
          </h1>

          <p class="mt-6 text-base md:text-lg text-ink-muted leading-relaxed max-w-lg">
            Conectamos produtores, cooperativas, indústria e exportadores com
            seriedade e proximidade — do grão à liquidação, em toda safra.
          </p>

          <div class="mt-10 flex flex-wrap items-center gap-4">
            <a
              href="/contato"
              class="inline-flex items-center gap-1.5 bg-brand hover:bg-brand-dark text-paper text-sm md:text-base font-medium px-6 py-3 rounded-full transition-colors duration-200"
            >
              Fale Conosco
              <span aria-hidden="true">→</span>
            </a>
            <a
              href="/servicos"
              class="inline-flex items-center gap-1.5 text-ink hover:text-brand text-sm md:text-base font-medium px-2 py-3 transition-colors"
            >
              Conheça nossos serviços
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>

        <div class="relative">
          <div
            class="relative aspect-[5/4] lg:aspect-square rounded-xl overflow-hidden bg-paper-alt shadow-[0_30px_60px_-20px_rgba(20,19,17,0.25)]"
          >
            <Image
              src={cafezalAereo}
              alt="Vista aérea de cafezal com colheitadeira em operação"
              widths={[600, 900, 1200]}
              sizes="(max-width: 1024px) 92vw, 52vw"
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>

          <div
            class="absolute -bottom-16 md:-bottom-24 right-2 md:right-8 w-[58%] md:w-[50%] aspect-[4/5] rounded-xl overflow-hidden border-[6px] md:border-[10px] border-paper shadow-[0_24px_48px_-12px_rgba(20,19,17,0.35)]"
          >
            <Image
              src={provaDeXicara}
              alt="Prova de xícara — classificação sensorial de café por especialistas"
              widths={[320, 480, 700]}
              sizes="(max-width: 768px) 56vw, 30vw"
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section
    class="bg-paper-alt border-t border-line"
    aria-labelledby="depoimento-titulo"
  >
    <h2 id="depoimento-titulo" class="sr-only">Depoimento</h2>
    <div class="max-w-4xl mx-auto px-6 md:px-10 py-16 md:py-24">
      <figure>
        <svg
          class="w-10 h-10 text-brand/30 mb-6"
          fill="currentColor"
          viewBox="0 0 32 32"
          aria-hidden="true"
        >
          <path
            d="M10 8c-4.418 0-8 3.582-8 8 0 3.866 2.686 7 6 8v-2c-2.21-.88-4-3-4-6 0-3.314 2.686-6 6-6V8zm14 0c-4.418 0-8 3.582-8 8 0 3.866 2.686 7 6 8v-2c-2.21-.88-4-3-4-6 0-3.314 2.686-6 6-6V8z"
          ></path>
        </svg>
        <blockquote
          class="text-xl md:text-2xl lg:text-3xl font-medium text-ink leading-snug max-w-3xl"
        >
          Em 15 anos trabalhando com a Safras, nunca tive surpresa ruim.
          Compromisso, clareza nos contratos e pagamento em dia. Não é só
          vender café — é construir uma relação em que eu posso planejar
          minha safra sem medo.
        </blockquote>
        <figcaption class="mt-8 text-sm text-ink-muted">
          — <span class="font-semibold text-ink">João Batista Pereira</span>,
          Produtor · Sul de Minas, MG
        </figcaption>
      </figure>
      <p class="mt-6 text-xs italic text-ink-muted/70">
        ⚠ Depoimento exemplo — substituir por depoimento real antes de publicar
      </p>
    </div>
  </section>

  <section
    class="bg-paper border-t border-line"
    aria-labelledby="servicos-titulo"
  >
    <div class="max-w-7xl mx-auto px-6 md:px-10 py-20 md:py-28 lg:py-32">
      <div
        class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-14 md:mb-20"
      >
        <div class="max-w-2xl">
          <span
            class="inline-block text-xs font-semibold uppercase tracking-[0.22em] text-brand mb-5"
          >
            [ Serviços ]
          </span>
          <h2
            id="servicos-titulo"
            class="text-3xl md:text-4xl lg:text-[2.75rem] font-semibold text-ink leading-[1.1] tracking-tight"
          >
            Do grão ao negócio, com quem
            <span class="text-brand">conhece o café por dentro.</span>
          </h2>
          <p class="mt-5 text-base md:text-lg text-ink-muted leading-relaxed max-w-xl">
            Três frentes de atuação que, juntas, garantem que cada saca saia
            da lavoura pro mercado certo — no momento certo, no preço justo.
          </p>
        </div>

        <a
          href="/servicos"
          class="inline-flex items-center gap-1.5 text-brand hover:text-brand-dark font-medium text-sm whitespace-nowrap border-b border-brand/30 hover:border-brand pb-1 self-start md:self-auto md:mb-2 transition-colors"
        >
          Ver todos os serviços
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div
        id="servicos-accordion"
        class="flex flex-col md:flex-row gap-4 md:gap-5 md:h-[500px] lg:h-[540px]"
      >
        {
          services.map((service, idx) => (
            <article
              data-service-card
              data-active={idx === 0 ? "true" : "false"}
              class="group relative overflow-hidden rounded-xl bg-paper-alt border border-dashed border-line cursor-pointer flex-1 md:flex-[1_1_0%] data-[active=true]:md:flex-[2.5_1_0%] data-[active=true]:border-solid data-[active=true]:border-brand-dark h-[320px] md:h-full transition-[flex,border-color] duration-500 ease-[cubic-bezier(0.29,0,0.2,1)] focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-4"
              tabindex="0"
              aria-label={`Serviço ${service.number}: ${service.title}`}
            >
              <div
                aria-hidden="true"
                class="absolute inset-0 bg-paper/90 group-data-[active=true]:bg-[linear-gradient(180deg,rgba(19,64,36,0)_20%,rgba(1,61,1,0.95)_100%)] transition-all duration-[600ms] ease-[cubic-bezier(0.48,0,0.11,1)]"
              />

              <div class="relative h-full p-6 md:p-7 flex flex-col justify-between">
                <div class="flex items-start justify-between gap-4">
                  <div
                    class="w-12 h-12 md:w-14 md:h-14 rounded-xl flex items-center justify-center bg-ink text-brand group-data-[active=true]:bg-brand group-data-[active=true]:text-paper transition-colors duration-500 ease-[cubic-bezier(0.48,0,0.11,1)] shrink-0"
                    aria-hidden="true"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      set:html={service.iconSvg}
                    />
                  </div>
                  <span
                    class="text-4xl md:text-5xl lg:text-6xl font-semibold text-paper leading-none tracking-tight opacity-0 group-data-[active=true]:opacity-100 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] delay-[700ms]"
                    aria-hidden="true"
                  >
                    {service.number}
                  </span>
                </div>

                <div>
                  <h3 class="sr-only">{service.title}</h3>

                  <div class="grid" aria-hidden="true">
                    <span
                      class="col-start-1 row-start-1 self-end text-base md:text-lg font-semibold text-ink leading-[1.2] tracking-tight line-clamp-2 transition-opacity duration-[300ms] ease-[cubic-bezier(0.48,0,0.11,1)] group-data-[active=true]:opacity-0"
                    >
                      {service.title}
                    </span>
                    <span
                      class="col-start-1 row-start-1 self-end text-xl md:text-2xl lg:text-3xl font-semibold text-paper leading-[1.15] tracking-tight line-clamp-2 opacity-0 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] delay-[300ms] group-data-[active=true]:opacity-100"
                    >
                      {service.title}
                    </span>
                  </div>

                  <div
                    class="h-px bg-paper/40 my-4 md:my-5 opacity-0 group-data-[active=true]:opacity-100 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] delay-[700ms]"
                    aria-hidden="true"
                  />
                  <p
                    class="text-sm md:text-base text-paper/90 leading-relaxed opacity-0 group-data-[active=true]:opacity-100 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] delay-[700ms]"
                  >
                    {service.description}
                  </p>
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <p class="mt-10 text-xs italic text-ink-muted/70">
        ⚠ Conteúdo dos serviços em rascunho — confirmar descrições com a
        Safras antes de publicar.
      </p>
    </div>
  </section>

  <script>
    const cards = document.querySelectorAll<HTMLElement>("[data-service-card]");

    const activate = (target: HTMLElement) => {
      cards.forEach((card) => {
        card.dataset.active = card === target ? "true" : "false";
      });
    };

    cards.forEach((card) => {
      card.addEventListener("mouseenter", () => activate(card));
      card.addEventListener("focus", () => activate(card));
    });
  </script>
</BaseLayout>
