---
/**
 * Página de manutenção. Standalone — não usa BaseLayout porque o site
 * fica reduzido a esta página enquanto MAINTENANCE=1 no Cloud Build.
 * Sem header, footer ou modal. Tokens hardcoded localmente pra a página
 * não depender de global.css (mais leve e self-contained).
 */
import { Image } from "astro:assets";
import logo from "../assets/branding/safras-logotipo.svg";
import "@fontsource-variable/inter";

const publicEmail = "atendimento@safrasnegocios.com.br";
const whatsappHref = `https://wa.me/553535314046?text=${encodeURIComponent(
  "Olá! Encontrei a Safras & Negócios pelo site e gostaria de mais informações.",
)}`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#025c00" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>Em breve | Safras & Negócios</title>
    <meta
      name="description"
      content="Estamos preparando o novo site da Safras & Negócios. Em breve, voltamos."
    />
  </head>
  <body>
    <main class="page">
      <div class="stack">
        <Image
          src={logo}
          alt="Safras & Negócios"
          width={140}
          loading="eager"
          class="logo"
        />
        <span class="eyebrow">Em breve</span>
        <h1>Estamos preparando uma nova safra para você.</h1>
        <p>Em breve, um novo site. Por enquanto, fale com a gente.</p>
        <div class="contact">
          <a
            class="cta-whatsapp"
            href={whatsappHref}
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg
              viewBox="0 0 24 24"
              fill="currentColor"
              width="18"
              height="18"
              aria-hidden="true"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"
              ></path>
            </svg>
            <span>(35) 3531-4046</span>
          </a>
          <a href={`mailto:${publicEmail}`} class="email">
            {publicEmail}
          </a>
        </div>
      </div>
      <footer class="signature">
        © {new Date().getFullYear()} Safras &amp; Negócios
      </footer>
    </main>

    <style>
      :root {
        --color-paper-alt: #f6f6f4;
        --color-ink: #141311;
        --color-ink-muted: #5a564f;
        --color-brand: #025c00;
        --color-brand-dark: #013d01;
        --color-earth: #3c3424;
        --font-sans: "Inter Variable", ui-sans-serif, system-ui, -apple-system,
          "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        font-family: var(--font-sans);
        color: var(--color-ink);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      .page {
        position: relative;
        min-height: 100svh;
        display: grid;
        place-items: center;
        background-color: var(--color-paper-alt);
        background-image:
          radial-gradient(
            ellipse 70% 55% at 100% 0%,
            rgba(60, 52, 36, 0.08) 0%,
            rgba(60, 52, 36, 0) 65%
          ),
          radial-gradient(
            ellipse 60% 50% at 0% 100%,
            rgba(2, 92, 0, 0.04) 0%,
            rgba(2, 92, 0, 0) 60%
          );
        padding: 2.5rem 1.5rem;
      }

      .stack {
        max-width: 34rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        animation: fade-up 700ms cubic-bezier(0.22, 1, 0.36, 1) both;
      }

      .logo {
        width: 140px;
        height: auto;
        filter: drop-shadow(0 10px 30px rgba(60, 52, 36, 0.14));
      }

      .eyebrow {
        font-size: 0.75rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--color-brand);
        font-weight: 600;
        margin-top: 0.25rem;
      }

      h1 {
        margin: 0;
        font-size: clamp(1.75rem, 4.5vw, 2.875rem);
        font-weight: 500;
        line-height: 1.15;
        letter-spacing: -0.012em;
        color: var(--color-ink);
        text-wrap: balance;
      }

      p {
        margin: 0;
        font-size: 1.0625rem;
        line-height: 1.55;
        color: var(--color-ink-muted);
        text-wrap: balance;
        max-width: 28rem;
      }

      .contact {
        margin-top: 0.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.875rem;
      }

      .cta-whatsapp {
        display: inline-flex;
        align-items: center;
        gap: 0.625rem;
        background-color: var(--color-brand);
        color: #ffffff;
        padding: 0.875rem 1.5rem;
        border-radius: 9999px;
        font-size: 0.9375rem;
        font-weight: 500;
        letter-spacing: -0.005em;
        text-decoration: none;
        box-shadow: 0 6px 20px rgba(2, 92, 0, 0.18);
        transition:
          background-color 200ms ease,
          transform 200ms ease,
          box-shadow 200ms ease;
      }

      .cta-whatsapp:hover,
      .cta-whatsapp:focus-visible {
        background-color: var(--color-brand-dark);
        transform: translateY(-1px);
        box-shadow: 0 10px 28px rgba(2, 92, 0, 0.22);
      }

      .cta-whatsapp svg {
        flex: none;
      }

      .email {
        font-size: 0.9375rem;
        color: var(--color-brand);
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 5px;
        transition: color 200ms ease;
      }

      .email:hover,
      .email:focus-visible {
        color: var(--color-brand-dark);
      }

      .signature {
        position: absolute;
        bottom: 1.5rem;
        left: 0;
        right: 0;
        text-align: center;
        font-size: 0.75rem;
        color: var(--color-ink-muted);
        opacity: 0.65;
        letter-spacing: 0.04em;
      }

      :focus-visible {
        outline: 2px solid var(--color-brand);
        outline-offset: 4px;
        border-radius: 2px;
      }

      @keyframes fade-up {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .stack {
          animation: fade-in 400ms ease both;
        }
        @keyframes fade-in {
          from {
            opacity: 0;
          }
          to {
            opacity: 1;
          }
        }
      }
    </style>
  </body>
</html>
