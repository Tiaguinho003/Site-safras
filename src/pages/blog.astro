---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Blog | Safras & Negócios">
  <section
    class="max-w-4xl mx-auto px-6 md:px-10 py-24 md:py-32 text-center"
  >
    <p
      class="inline-block text-xs font-semibold uppercase tracking-[0.22em] text-brand mb-5"
    >
      [ Em construção ]
    </p>
    <h1 class="text-3xl md:text-5xl font-semibold text-ink leading-tight">
      Blog
    </h1>
    <p class="mt-5 text-lg text-ink-muted max-w-xl mx-auto">
      Em breve: artigos, cases e análises produzidas pela equipe da
      Safras & Negócios sobre o mercado do café.
    </p>
  </section>
</BaseLayout>
