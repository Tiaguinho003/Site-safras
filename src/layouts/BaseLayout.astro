---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import ContactModal from "../components/layout/ContactModal.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Safras & Negócios — corretora de café com tradição, confiança, clareza e praticidade.",
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#025c00" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={Astro.url.href} />
    <title>{title}</title>
  </head>
  <body class="flex flex-col min-h-screen">
    <a
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-brand focus:text-paper focus:px-4 focus:py-2 focus:rounded-md focus:font-medium"
      href="#conteudo"
    >
      Pular para o conteúdo
    </a>

    <Header />

    <main id="conteudo" class="flex-1">
      <slot />
    </main>

    <Footer />

    <ContactModal />

    <script>
      import Lenis from "lenis";
      import "lenis/dist/lenis.css";

      const prefersReduced = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      if (!prefersReduced) {
        const lenis = new Lenis({
          duration: 1.1,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
        });

        const raf = (time: number) => {
          lenis.raf(time);
          requestAnimationFrame(raf);
        };
        requestAnimationFrame(raf);
      }
    </script>
  </body>
</html>
