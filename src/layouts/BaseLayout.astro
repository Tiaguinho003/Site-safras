---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import {
  getCurrentLocale,
  localizeURL,
  LOCALES,
  LOCALE_LABELS,
  DEFAULT_LOCALE,
  t,
} from "../i18n";

interface Props {
  title: string;
  description?: string;
  socialImage?: string;
  socialImageAlt?: string;
  socialImageWidth?: number;
  socialImageHeight?: number;
  canonical?: boolean;
  alternates?: boolean;
  noindex?: boolean;
  structuredData?: Record<string, unknown>;
}

const locale = getCurrentLocale(Astro);
const bcp47 = LOCALE_LABELS[locale].bcp47;

const {
  title,
  description = t("meta.siteDescription", locale),
  socialImage,
  socialImageAlt = t("meta.socialImageAlt", locale),
  socialImageWidth,
  socialImageHeight,
  canonical = true,
  alternates = true,
  noindex = false,
  structuredData,
} = Astro.props;

// SEO multi-idioma: hreflang alternates pra cada locale + x-default.
// Astro.site é a URL base (https://safrasenegocios.com.br).
const baseUrl = Astro.site ?? new URL("https://safrasenegocios.com.br");
const siteUrl = baseUrl.toString().replace(/\/$/, "");
const currentPath = Astro.url.pathname;
const canonicalHref = new URL(currentPath, baseUrl).href;
const socialImageHref = socialImage
  ? new URL(socialImage, baseUrl).href
  : undefined;
const hreflangs = LOCALES.map((l) => ({
  hreflang: LOCALE_LABELS[l].bcp47,
  href: siteUrl + localizeURL(currentPath, l),
}));
const xDefaultHref = siteUrl + localizeURL(currentPath, DEFAULT_LOCALE);
const languageOptions = LOCALES.map((targetLocale) => ({
  locale: targetLocale,
  browserBase: targetLocale === "pt-br" ? "pt" : targetLocale,
  href: localizeURL(currentPath, targetLocale),
  prompt: t("languageSuggestion.prompt", targetLocale),
  accept: t("languageSuggestion.accept", targetLocale),
  dismiss: t("languageSuggestion.dismiss", targetLocale),
}));
---

<!doctype html>
<html lang={bcp47}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#025c00" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    {canonical && <link rel="canonical" href={canonicalHref} />}
    {/* hreflang alternates pra SEO multi-idioma */}
    {alternates && hreflangs.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    {alternates && <link rel="alternate" hreflang="x-default" href={xDefaultHref} />}

    <title>{title}</title>
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Safras & Negócios" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:locale" content={bcp47.replace("-", "_")} />
    {LOCALES.filter((item) => item !== locale).map((item) => (
      <meta
        property="og:locale:alternate"
        content={LOCALE_LABELS[item].bcp47.replace("-", "_")}
      />
    ))}
    {socialImageHref && <meta property="og:image" content={socialImageHref} />}
    {socialImageHref && <meta property="og:image:alt" content={socialImageAlt} />}
    {socialImageHref && socialImageWidth && (
      <meta property="og:image:width" content={String(socialImageWidth)} />
    )}
    {socialImageHref && socialImageHeight && (
      <meta property="og:image:height" content={String(socialImageHeight)} />
    )}
    <meta
      name="twitter:card"
      content={socialImageHref ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImageHref && <meta name="twitter:image" content={socialImageHref} />}
    {socialImageHref && <meta name="twitter:image:alt" content={socialImageAlt} />}
    {structuredData && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(structuredData)}
      />
    )}

  </head>
  <body class="flex flex-col min-h-screen">
    <aside
      id="language-suggestion"
      class="fixed inset-x-4 top-4 z-[80] mx-auto max-w-2xl rounded-2xl border border-line bg-paper/95 p-4 shadow-xl backdrop-blur-md md:flex md:items-center md:gap-5 md:px-5"
      role="status"
      aria-live="polite"
      hidden
    >
      <p
        class="flex-1 text-sm font-medium text-ink"
        data-language-suggestion-prompt
      ></p>
      <div class="mt-3 flex flex-wrap items-center gap-2 md:mt-0">
        <a
          class="inline-flex min-h-11 items-center justify-center rounded-full bg-brand px-4 py-2 text-sm font-semibold text-paper transition-colors hover:bg-brand-dark focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
          data-language-suggestion-accept
        ></a>
        <button
          type="button"
          class="inline-flex min-h-11 items-center justify-center rounded-full px-4 py-2 text-sm font-medium text-ink-muted transition-colors hover:bg-paper-alt hover:text-ink focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand"
          data-language-suggestion-dismiss
        ></button>
      </div>
    </aside>

    <script is:inline define:vars={{ locale, languageOptions }}>
      (function () {
        try {
          if (/(?:^|;\s*)safras_locale=/.test(document.cookie)) return;
          if (sessionStorage.getItem("safras_language_suggestion_dismissed")) return;

          var languages =
            navigator.languages && navigator.languages.length
              ? navigator.languages
              : [navigator.language || "pt-BR"];
          var target = null;

          for (var i = 0; i < languages.length; i++) {
            var base = (languages[i] || "").toLowerCase().split("-")[0];
            var candidate = languageOptions.find(function (option) {
              return option.browserBase === base;
            });
            if (candidate) {
              target = candidate;
              break;
            }
          }

          if (!target || target.locale === locale) return;

          var banner = document.getElementById("language-suggestion");
          if (!banner) return;
          var prompt = banner.querySelector("[data-language-suggestion-prompt]");
          var accept = banner.querySelector("[data-language-suggestion-accept]");
          var dismiss = banner.querySelector("[data-language-suggestion-dismiss]");
          if (!prompt || !accept || !dismiss) return;

          prompt.textContent = target.prompt;
          accept.textContent = target.accept;
          accept.setAttribute("href", target.href + window.location.hash);
          dismiss.textContent = target.dismiss;
          banner.hidden = false;

          accept.addEventListener("click", function () {
            document.cookie =
              "safras_locale=" +
              encodeURIComponent(target.locale) +
              "; path=/; max-age=31536000; SameSite=Lax";
          });
          dismiss.addEventListener("click", function () {
            sessionStorage.setItem("safras_language_suggestion_dismissed", "1");
            banner.hidden = true;
          });
        } catch (error) {
          // A sugestão é progressiva; qualquer falha mantém a URL solicitada.
        }
      })();
    </script>

    <a
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-brand focus:text-paper focus:px-4 focus:py-2 focus:rounded-md focus:font-medium"
      href="#conteudo"
    >
      {t("common.skipToContent", locale)}
    </a>

    <Header />

    <main id="conteudo" class="flex-1">
      <slot />
    </main>

    <Footer />

    <script>
      const reducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      );

      /* ===== Smooth-scroll unificado pra anchors/buttons =====
         Offset calibrado pra section.top cair ABAIXO da linha de trigger do
         scroll-spy (100px) — assim a seção ativa o estado verde no header.
         Usa a rolagem nativa e respeita reduced-motion. */
      const getScrollOffset = (): number =>
        window.matchMedia("(min-width: 768px)").matches ? -90 : -70;

      const smoothScrollTo = (target: HTMLElement | number) => {
        const top =
          typeof target === "number"
            ? target
            : target.getBoundingClientRect().top +
              window.scrollY +
              getScrollOffset();
        window.scrollTo({
          top,
          behavior: reducedMotion.matches ? "auto" : "smooth",
        });
      };

      // Expõe pra Footer "Topo", hero "Explorar Serviços", scroll-next etc.
      (window as Window & { __smoothScrollTo?: typeof smoothScrollTo }).__smoothScrollTo =
        smoothScrollTo;

      // Intercepta TODOS os cliques em anchors da mesma página
      document.addEventListener("click", (e) => {
        if (e.ctrlKey || e.metaKey || e.shiftKey) return;
        const target = e.target as Element | null;
        if (!target) return;

        const link = target.closest('a[href*="#"]') as HTMLAnchorElement | null;
        if (!link) return;
        if (link.target === "_blank") return;
        if (link.hasAttribute("download")) return;

        const href = link.getAttribute("href");
        if (!href) return;

        let url: URL;
        try {
          url = new URL(href, window.location.href);
        } catch {
          return;
        }

        // Só intercepta anchors da MESMA página. Normaliza trailing slash
        // (config tem trailingSlash:"never", mas links podem ter "/").
        const normalize = (p: string) => p.replace(/\/$/, "") || "/";
        if (normalize(url.pathname) !== normalize(window.location.pathname))
          return;
        if (!url.hash || url.hash === "#") return;

        const id = decodeURIComponent(url.hash.slice(1));
        const targetEl = document.getElementById(id);
        if (!targetEl) return;

        e.preventDefault();
        smoothScrollTo(targetEl);

        // Atualiza URL sem disparar scroll nativo
        if (history.pushState) {
          history.pushState(null, "", url.hash);
        }
      });
    </script>
  </body>
</html>
