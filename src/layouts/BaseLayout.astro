---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Safras & Negócios — corretora de café com confiança, tradição, clareza e praticidade.",
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1f6b3a" />
    <link rel="canonical" href={Astro.url.href} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
