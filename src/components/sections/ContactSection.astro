---
import { Image } from "astro:assets";
import brasilMap from "../../assets/maps/brasil-pontilhado.png";
import { useTranslation, getAnchor } from "../../i18n";

const { t, locale } = useTranslation(Astro);
const contatoId = getAnchor("contato", locale);
const publicEmail = t("contact.details.email");
const publicPhone = t("contact.details.phone");
const phoneHref = "tel:+553535314046";
const whatsappHref = `https://wa.me/553535314046?text=${encodeURIComponent(
  t("contact.whatsappPrefill"),
)}`;
const mapHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(
  t("contact.details.address"),
)}`;

/**
 * Marcadores sobre o mapa. Label vem do dict (mantém São Sebastião do
 * Paraíso como nome próprio mas pode ajustar formatação por idioma).
 */
const marcadores: { label: string; top: number; left: number }[] = [
  { label: t("contact.cityMarkerLabel"), top: 49.0, left: 33.0 },
];
---

<section
  id={contatoId}
  aria-labelledby="contact-title"
  class="bg-paper scroll-mt-[70px] md:scroll-mt-[90px]"
>
  <h2 id="contact-title" class="sr-only">{t("contact.sectionAriaLabel")}</h2>
  {/* ===== Mobile-only: bloco do mapa do Brasil antes do form (edge-to-edge) ===== */}
  <div class="contact-map-mobile md:hidden py-4" aria-hidden="true">
    <div class="relative">
      <Image
        src={brasilMap}
        alt=""
        widths={[480, 720, 960]}
        sizes="100vw"
        class="contact-map-bg-mobile w-full h-auto select-none"
        loading="lazy"
        fetchpriority="low"
        quality={60}
      />
      {marcadores.map((m) => (
        <div class="map-marker" style={`top: ${m.top}%; left: ${m.left}%;`}>
          <span class="map-marker-dot">
            <span class="map-marker-ring"></span>
            <span class="map-marker-ring map-marker-ring--delay"></span>
          </span>
          <svg
            class="map-marker-leader"
            viewBox="0 0 200 50"
            width="200"
            height="50"
          >
            <polyline
              points="8,50 48,10 198,10"
              fill="none"
              stroke="currentColor"
              stroke-width="1.25"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
          <span class="map-marker-label">{m.label}</span>
        </div>
      ))}
    </div>
  </div>

  {/* ===== Row 1: Form (mapa do Brasil de fundo, ancorado à esquerda — desktop only) ===== */}
  <div class="relative overflow-x-clip">
    {/* Wrapper dimensionado igual à img — markers % são relativos a este box.
        -top/-bottom estendem o campo da imagem além da Row 1 (revelando mais
        do PNG acima e abaixo). overflow-x-clip da Row 1 mantém clipping
        horizontal mas libera o vertical. */}
    <div
      class="contact-map-area hidden md:block absolute -top-16 bottom-24 left-0 pointer-events-none translate-y-24"
      aria-hidden="true"
    >
      <Image
        src={brasilMap}
        alt=""
        widths={[720, 960, 1200]}
        sizes="(min-width: 1024px) 55vw, 65vw"
        class="contact-map-bg w-full h-full select-none"
        loading="lazy"
        fetchpriority="low"
        quality={60}
      />
      {marcadores.map((m) => (
        <div class="map-marker" style={`top: ${m.top}%; left: ${m.left}%;`}>
          <span class="map-marker-dot">
            <span class="map-marker-ring"></span>
            <span class="map-marker-ring map-marker-ring--delay"></span>
          </span>
          <svg
            class="map-marker-leader"
            viewBox="0 0 200 50"
            width="200"
            height="50"
          >
            <polyline
              points="8,50 48,10 198,10"
              fill="none"
              stroke="currentColor"
              stroke-width="1.25"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
          <span class="map-marker-label">{m.label}</span>
        </div>
      ))}
    </div>
    <div class="relative max-w-[100rem] mx-auto px-6 md:px-10 pt-12 md:pt-16 lg:pt-20 pb-16 md:pb-20 lg:pb-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      {/* Header column — vazia por enquanto, só o tag (puxado pra cima no md+) */}
      <div class="md:-mt-8 lg:-mt-12">
        <span
          class="inline-block text-xs font-semibold uppercase tracking-[0.22em] text-brand"
        >
          {t("contact.sectionLabel")}
        </span>

        <address class="mt-8 md:mt-10 not-italic max-w-md rounded-3xl border border-line bg-paper/90 p-6 md:p-7 backdrop-blur-sm shadow-[0_18px_50px_-35px_rgba(20,19,17,0.35)]">
          <dl class="grid gap-5">
            <div>
              <dt class="text-[11px] font-semibold uppercase tracking-[0.18em] text-brand">
                {t("contact.details.emailLabel")}
              </dt>
              <dd class="mt-1.5 text-sm md:text-base text-ink">
                <a class="hover:text-brand transition-colors break-all" href={`mailto:${publicEmail}`}>
                  {publicEmail}
                </a>
              </dd>
            </div>
            <div>
              <dt class="text-[11px] font-semibold uppercase tracking-[0.18em] text-brand">
                {t("contact.details.phoneLabel")}
              </dt>
              <dd class="mt-1.5 text-sm md:text-base text-ink">
                <a class="hover:text-brand transition-colors" href={phoneHref}>
                  {t("contact.details.callAction")}: {publicPhone}
                </a>
              </dd>
            </div>
            <div>
              <dt class="text-[11px] font-semibold uppercase tracking-[0.18em] text-brand">
                {t("contact.details.addressLabel")}
              </dt>
              <dd class="mt-1.5 text-sm md:text-base leading-relaxed text-ink">
                <a
                  class="hover:text-brand transition-colors"
                  href={mapHref}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {t("contact.details.address")} <span aria-hidden="true">↗</span>
                </a>
              </dd>
            </div>
            <div>
              <dt class="text-[11px] font-semibold uppercase tracking-[0.18em] text-brand">
                {t("contact.details.hoursLabel")}
              </dt>
              <dd class="mt-1.5 text-sm md:text-base text-ink">
                {t("contact.details.hours")}
              </dd>
            </div>
          </dl>
        </address>
      </div>

      {/* Form column */}
      <div class="fade-in-up relative" data-reveal="fade-in-up">
        <form
          id="contact-form"
          novalidate
          data-state="idle"
          data-label-idle={t("contact.form.submitLabel")}
          data-label-sending={t("contact.form.submitSending")}
          aria-describedby="contact-form-privacy"
          aria-busy="false"
          class="space-y-7 relative"
        >
          {/* Honeypot — bots preenchem, humanos não veem */}
          <div
            class="absolute left-[-9999px] top-[-9999px] h-0 w-0 overflow-hidden"
            aria-hidden="true"
          >
            <label>
              {t("contact.form.honeypotLabel")}
              <input type="text" name="company" tabindex="-1" autocomplete="off" />
            </label>
          </div>

          {/* Nome + E-mail */}
          <div class="grid md:grid-cols-2 gap-6">
            <div class="contact-field">
              <label for="cf-nome">{t("contact.form.labels.name")}</label>
              <input
                id="cf-nome"
                name="nome"
                type="text"
                required
                autocomplete="name"
                placeholder={t("contact.form.placeholders.name")}
              />
            </div>
            <div class="contact-field">
              <label for="cf-email">{t("contact.form.labels.email")}</label>
              <input
                id="cf-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder={t("contact.form.placeholders.email")}
              />
            </div>
          </div>

          {/* Telefone + Estado — uma coluna no mobile para evitar campos comprimidos */}
          <div class="grid md:grid-cols-2 gap-6">
            <div class="contact-field">
              <label for="cf-telefone">{t("contact.form.labels.phone")}</label>
              <input
                id="cf-telefone"
                name="telefone"
                type="tel"
                autocomplete="tel"
                placeholder={t("contact.form.placeholders.phone")}
              />
            </div>
            <div class="contact-field contact-field--wide-label">
              <label for="cf-estado">{t("contact.form.labels.state")}</label>
              <input
                id="cf-estado"
                name="estado"
                type="text"
                autocomplete="address-level1"
                placeholder={t("contact.form.placeholders.state")}
              />
            </div>
          </div>

          {/* Perfil + Interesse — uma coluna no mobile para acomodar opções longas */}
          <div class="grid md:grid-cols-2 gap-6">
            <div class="contact-field contact-field--select">
              <label for="cf-perfil">{t("contact.form.labels.profile")}</label>
              <select id="cf-perfil" name="perfil" required>
                <option value="">{t("contact.form.placeholders.select")}</option>
                <option value="produtor">{t("contact.form.profileOptions.producer")}</option>
                <option value="comprador">{t("contact.form.profileOptions.buyer")}</option>
                <option value="exportador">{t("contact.form.profileOptions.exporter")}</option>
                <option value="cooperativa">{t("contact.form.profileOptions.cooperative")}</option>
                <option value="instituicao-financeira">{t("contact.form.profileOptions.financialInstitution")}</option>
                <option value="parceiro">{t("contact.form.profileOptions.partner")}</option>
                <option value="outro">{t("contact.form.profileOptions.other")}</option>
              </select>
            </div>
            <div class="contact-field contact-field--select">
              <label for="cf-interesse">{t("contact.form.labels.interest")}</label>
              <select id="cf-interesse" name="interesse">
                <option value="">{t("contact.form.placeholders.select")}</option>
                <option value="corretagem">{t("contact.form.interestOptions.brokerage")}</option>
                <option value="mercado-fisico">{t("contact.form.interestOptions.physicalMarket")}</option>
                <option value="mercado-futuro">{t("contact.form.interestOptions.futuresMarket")}</option>
                <option value="cpr">{t("contact.form.interestOptions.cpr")}</option>
                <option value="classificacao">{t("contact.form.interestOptions.grading")}</option>
                <option value="prova-sensorial">{t("contact.form.interestOptions.cupping")}</option>
                <option value="embarques-conferencias">{t("contact.form.interestOptions.logistics")}</option>
                <option value="outro">{t("contact.form.interestOptions.other")}</option>
              </select>
            </div>
          </div>

          {/* Mensagem (textarea) */}
          <div class="contact-field contact-field--textarea">
            <label for="cf-mensagem">{t("contact.form.labels.message")}</label>
            <textarea
              id="cf-mensagem"
              name="mensagem"
              rows="4"
              placeholder={t("contact.form.placeholders.message")}></textarea>
          </div>

          {/* Erro */}
          <div
            data-form-error
            hidden
            role="alert"
            tabindex="-1"
            class="text-sm text-red-700 bg-red-50 border border-red-200 rounded-2xl px-4 py-3"
          >
            <p>{t("contact.form.states.errorDetailed")}</p>
            <p class="mt-2 flex flex-wrap items-center gap-x-2 gap-y-1 font-medium">
              <a class="underline underline-offset-2" href={`mailto:${publicEmail}`}>
                {publicEmail}
              </a>
              <span aria-hidden="true">•</span>
              <a
                class="underline underline-offset-2"
                href={whatsappHref}
                target="_blank"
                rel="noopener noreferrer"
              >
                {t("contact.details.whatsappAction")}
              </a>
            </p>
          </div>

          {/* Aviso resumido sobre o uso dos dados enviados */}
          <p id="contact-form-privacy" class="text-xs leading-relaxed text-ink-muted">
            {t("contact.form.privacySummary")}
          </p>

          {/* Submit */}
          <div class="pt-2">
            <button
              type="submit"
              data-form-submit
              class="w-full flex items-center justify-center gap-2 bg-brand hover:bg-brand-dark disabled:opacity-60 disabled:cursor-not-allowed text-paper text-base font-medium px-8 py-4 rounded-full transition-colors duration-200"
            >
              <span data-submit-label>{t("contact.form.submitLabel")}</span>
              <span data-submit-arrow aria-hidden="true">→</span>
              <span data-submit-spinner hidden aria-hidden="true" class="inline-flex">
                <svg
                  class="w-4 h-4 animate-spin"
                  fill="none"
                  viewBox="0 0 24 24"
                >
                  <circle
                    cx="12"
                    cy="12"
                    r="10"
                    stroke="currentColor"
                    stroke-width="3"
                    opacity="0.25"></circle>
                  <path
                    fill="currentColor"
                    d="M4 12a8 8 0 018-8v3a5 5 0 00-5 5H4z"></path>
                </svg>
              </span>
            </button>
          </div>
        </form>

        {/* Confirmação textual de envio */}
        <div
          data-form-success
          hidden
          role="status"
          aria-live="polite"
          class="success-overlay"
        >
          <p class="max-w-md px-6 text-center text-lg md:text-xl font-medium leading-relaxed text-brand-dark">
            {t("contact.form.successMessage")}
          </p>
        </div>
      </div>
    </div>
  </div>
  </div>

</section>

<style>
  /* Wrapper do mapa: define o bounding box (markers % são relativos a este box) */
  .contact-map-area {
    width: 100%;
  }
  @media (min-width: 768px) {
    .contact-map-area {
      width: 65%;
    }
  }
  @media (min-width: 1024px) {
    .contact-map-area {
      width: 55%;
    }
  }

  /* === Mobile-only: mapa como bloco próprio antes do contato === */
  .contact-map-mobile {
    width: 100%;
    position: relative;
    overflow: hidden;
  }
  .contact-map-mobile img {
    width: 100%;
    /* Corta 10% do rodapé via aspect-ratio + object-position top.
       Natural é 1122/1402 (≈0.80); usamos 1122/1262 (≈0.89) pra cortar 10%
       da altura. O efeito de fade vertical (mask gradient) acompanha a
       nova altura, ficando mais perto do form do Contato. */
    aspect-ratio: 1122 / 1262;
    height: auto;
    object-fit: cover;
    object-position: top center;
    opacity: 0.85;
    -webkit-mask-image:
      linear-gradient(to bottom, transparent 0%, black 14%, black 86%, transparent 100%);
    mask-image:
      linear-gradient(to bottom, transparent 0%, black 14%, black 86%, transparent 100%);
  }
  .contact-map-mobile .map-marker {
    position: absolute;
  }

  /* Background mapa do Brasil — ocupa o wrapper, esfumaçado nas bordas */
  .contact-map-bg {
    object-fit: cover;
    object-position: center 30%;
    opacity: 0.85;
    -webkit-mask-image:
      linear-gradient(to right, black 65%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, black 10%),
      linear-gradient(to top, transparent 0%, black 16%);
    -webkit-mask-composite: source-in;
    mask-image:
      linear-gradient(to right, black 65%, transparent 100%),
      linear-gradient(to bottom, transparent 0%, black 10%),
      linear-gradient(to top, transparent 0%, black 16%);
    mask-composite: intersect;
  }

  /* Marcadores sobre o mapa: dot pulsante + linha leader + label */
  .map-marker {
    position: absolute;
    color: var(--color-brand);
    z-index: 2;
  }

  /* Bolinha verde, centrada nas coords */
  .map-marker-dot {
    position: absolute;
    top: 0;
    left: 0;
    transform: translate(-50%, -50%);
    width: 11px;
    height: 11px;
    background: currentColor;
    border-radius: 9999px;
    box-shadow: 0 0 0 2.5px rgb(255 255 255 / 0.95);
    z-index: 3;
  }
  .map-marker-ring {
    position: absolute;
    inset: 0;
    border-radius: 9999px;
    background: currentColor;
    opacity: 0.55;
    animation: map-pulse 2.4s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
  .map-marker-ring--delay {
    animation-delay: 1.2s;
  }
  @keyframes map-pulse {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    80% {
      transform: scale(4);
      opacity: 0;
    }
    100% {
      transform: scale(4);
      opacity: 0;
    }
  }

  /* Leader: diagonal + horizontal saindo da bolinha pra cima-direita */
  .map-marker-leader {
    position: absolute;
    top: -50px;
    left: 0;
    pointer-events: none;
    opacity: 0.75;
  }

  /* Label em cima da linha horizontal */
  .map-marker-label {
    position: absolute;
    top: -64px;
    left: 50px;
    white-space: nowrap;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-ink);
    background: rgb(255 255 255 / 0.92);
    padding: 3px 8px;
    border-radius: 3px;
    backdrop-filter: blur(2px);
  }

  @media (prefers-reduced-motion: reduce) {
    .map-marker-ring,
    .map-marker-ring--delay {
      animation: none;
      opacity: 0;
    }
  }

  /* Top labels (mobile + selects + textarea) */
  .contact-field {
    position: relative;
  }
  .contact-field > label {
    display: block;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink);
    pointer-events: none;
  }
  .contact-field input,
  .contact-field select,
  .contact-field textarea {
    width: 100%;
    padding: 0.875rem 1.25rem;
    font-size: 0.95rem;
    line-height: 1.4;
    color: var(--color-ink);
    background-color: var(--color-paper);
    border: 1.5px solid rgb(20 19 17 / 0.22);
    border-radius: 9999px;
    transition: border-color 0.2s, box-shadow 0.2s;
    font-family: inherit;
  }
  .contact-field input:hover:not(:focus),
  .contact-field select:hover:not(:focus),
  .contact-field textarea:hover:not(:focus) {
    border-color: rgb(20 19 17 / 0.34);
  }
  .contact-field input::placeholder,
  .contact-field textarea::placeholder {
    color: var(--color-ink-muted);
    opacity: 0.55;
  }
  .contact-field input:focus,
  .contact-field select:focus,
  .contact-field textarea:focus {
    outline: none;
    border-color: var(--color-brand);
    box-shadow: 0 0 0 3px rgb(2 92 0 / 0.12);
  }

  /* Textarea — rounded mas não pill (impossível com min-h) */
  .contact-field--textarea textarea {
    border-radius: 1.5rem;
    min-height: 140px;
    resize: vertical;
    padding: 1rem 1.25rem;
  }

  /* Select — chevron custom, top label sempre (validação flagou conflito de clique
     com floating label em selects native) */
  .contact-field--select select {
    appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' fill='none' stroke='%235a564f' stroke-width='1.75' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' d='M6 9l6 6 6-6'/></svg>");
    background-repeat: no-repeat;
    background-position: right 1.25rem center;
    padding-right: 2.75rem;
  }

  /* Floating labels — apenas md+ e apenas em inputs single-line text/email/tel.
     Inspirado no padrão Apexus (label absoluta com divisor vertical). */
  @media (min-width: 768px) {
    .contact-field:not(.contact-field--select):not(.contact-field--textarea) > label {
      position: absolute;
      left: 0.5rem;
      top: 50%;
      transform: translateY(-50%);
      z-index: 1;
      margin-bottom: 0;
      padding: 0.5rem 1.5rem;
      font-size: 0.95rem;
      line-height: 1.5;
    }
    .contact-field:not(.contact-field--select):not(.contact-field--textarea)
      > label::after {
      content: "";
      position: absolute;
      top: 0;
      left: 92px;
      height: 100%;
      width: 1px;
      background-color: var(--color-line);
    }
    .contact-field:not(.contact-field--select):not(.contact-field--textarea) input {
      padding-left: 108px;
    }
    .contact-field--wide-label > label::after {
      left: 132px !important;
    }
    .contact-field--wide-label input {
      padding-left: 148px !important;
    }
  }

  /* ====== Confirmação textual sobre o formulário ====== */
  .success-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgb(255 255 255 / 0.94);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: 1.5rem;
    z-index: 5;
  }
  .success-overlay[hidden] {
    display: none;
  }

  /* Reduced-motion: nada de animação extra (fade-in-up e split-text já tratados
     no observer global de index.astro). */
  @media (prefers-reduced-motion: reduce) {
    .contact-field input,
    .contact-field select,
    .contact-field textarea {
      transition: none;
    }
  }

  @media (max-width: 767px) {
    .map-marker-ring,
    .map-marker-ring--delay {
      animation: none;
      opacity: 0;
    }
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;

  if (form) {
    const submitBtn = form.querySelector<HTMLButtonElement>("[data-form-submit]");
    const submitLabel = form.querySelector<HTMLElement>("[data-submit-label]");
    const submitArrow = form.querySelector<HTMLElement>("[data-submit-arrow]");
    const submitSpinner = form.querySelector<HTMLElement>("[data-submit-spinner]");
    const errorBox = form.querySelector<HTMLElement>("[data-form-error]");
    const successBox = document.querySelector<HTMLElement>("[data-form-success]");

    // Strings traduzidas vêm via data-attr (setadas pelo template, locale-aware)
    const labelIdle = form.dataset.labelIdle ?? "Send";
    const labelSending = form.dataset.labelSending ?? "Sending...";

    function setSubmittingState(submitting: boolean) {
      form!.setAttribute("aria-busy", String(submitting));
      if (submitBtn) submitBtn.disabled = submitting;
      if (submitSpinner) submitSpinner.hidden = !submitting;
      if (submitArrow) submitArrow.hidden = submitting;
      if (submitLabel)
        submitLabel.textContent = submitting ? labelSending : labelIdle;
    }

    function showSuccess() {
      form!.setAttribute("data-state", "success");
      form!.reset();
      if (successBox) successBox.hidden = false;
      window.setTimeout(() => {
        if (successBox) successBox.hidden = true;
        form!.setAttribute("data-state", "idle");
        setSubmittingState(false);
      }, 5000);
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      // Honeypot — bots preenchem, finge sucesso
      const hp = (form.elements.namedItem("company") as HTMLInputElement)?.value;
      if (hp) {
        showSuccess();
        return;
      }

      setSubmittingState(true);
      if (errorBox) errorBox.hidden = true;
      form.setAttribute("data-state", "submitting");

      try {
        const accessKey = import.meta.env.PUBLIC_WEB3FORMS_KEY;
        if (!accessKey) throw new Error("PUBLIC_WEB3FORMS_KEY ausente");

        const getField = (name: string): string =>
          (form.elements.namedItem(name) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null)
            ?.value.trim() || "";

        const getSelectLabel = (name: string): string => {
          const select = form.elements.namedItem(name) as HTMLSelectElement | null;
          if (!select?.value) return "";
          return select.selectedOptions[0]?.textContent?.trim() || "";
        };

        const nome = getField("nome");
        const email = getField("email");
        const telefone = getField("telefone") || "—";
        const estado = getField("estado") || "—";
        const perfil = getSelectLabel("perfil") || getField("perfil");
        const interesse = getSelectLabel("interesse") || "—";
        const mensagem = getField("mensagem") || "—";
        const nomeAssunto = nome.replace(/[\r\n]+/g, " ").slice(0, 80);

        const enviadoEm = new Date().toLocaleString("pt-BR", {
          day: "2-digit",
          month: "2-digit",
          year: "numeric",
          hour: "2-digit",
          minute: "2-digit",
          timeZone: "America/Sao_Paulo",
        });

        const body = [
          "Novo contato pelo site Safras & Negócios",
          "",
          "CONTATO",
          "────────────────",
          `Nome:     ${nome}`,
          `E-mail:   ${email}`,
          `Telefone: ${telefone}`,
          `Estado:   ${estado}`,
          "",
          "SOLICITAÇÃO",
          "────────────────",
          `Perfil:    ${perfil}`,
          `Interesse: ${interesse}`,
          "",
          "MENSAGEM",
          "────────────────",
          mensagem,
          "",
          "─────────────────────────────",
          `Enviado ${enviadoEm} pelo formulário do site`,
        ].join("\n");

        const payload = new FormData();
        payload.append("access_key", accessKey);
        payload.append(
          "subject",
          `[Site] Novo contato — ${perfil} — ${interesse} — ${nomeAssunto}`,
        );
        payload.append("from_name", "Site Safras & Negócios");
        payload.append("replyto", email);
        payload.append("message", body);

        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          body: payload,
        });
        const data = await res.json();
        if (!res.ok || !data.success) {
          throw new Error(data.message || `HTTP ${res.status}`);
        }
        showSuccess();
      } catch (err) {
        if (errorBox) {
          errorBox.hidden = false;
          errorBox.focus();
        }
        setSubmittingState(false);
        form.setAttribute("data-state", "error");
      }
    });
  }
</script>
