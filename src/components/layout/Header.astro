---
import { Image } from "astro:assets";
import logoCompleto from "../../assets/branding/safras-logo-completo.svg";
import logoBranco from "../../assets/branding/safras-logo-branco.png";
import { mainNav } from "../../data/navigation";
import { useTranslation, DEFAULT_LOCALE } from "../../i18n";
import LanguageSwitcher from "./LanguageSwitcher.astro";

const { t, locale, localizeAnchor } = useTranslation(Astro);

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
// É a home da língua atual? (/, /en, /es)
const localeHomeForCurrent =
  locale === DEFAULT_LOCALE ? "/" : `/${locale}`;
const isHome =
  currentPath === localeHomeForCurrent ||
  currentPath === `${localeHomeForCurrent}/`;

const heroHref = localizeAnchor("hero");
const contactHref = localizeAnchor("contato");
---

{
  isHome && (
    <header
      data-header-hero
      class="site-header site-header--hero"
      aria-label={t("nav.heroHeaderAriaLabel")}
    >
      <div class="site-header__inner max-w-[100rem] mx-auto flex items-center justify-between gap-6">
        <a
          href={heroHref}
          class="site-header__logo flex items-center shrink-0"
          aria-label={t("nav.logoAriaLabel")}
        >
          <Image
            src={logoBranco}
            alt={t("brand.logoAlt")}
            height={224}
            class="site-header__logo-img w-auto"
            loading="eager"
          />
        </a>

        <nav aria-label={t("nav.mainMenu")} class="hidden lg:block flex-1">
          <ul class="flex items-center justify-center gap-10 lg:gap-14">
            {mainNav.map((item) => (
              <li>
                <a
                  data-nav-link
                  href={localizeAnchor(item.anchor)}
                  class="site-header__nav-link inline-flex flex-col items-center gap-1.5 text-base font-medium tracking-wide"
                >
                  <span>{t(item.labelKey)}</span>
                  <span class="site-header__nav-dot" aria-hidden="true" />
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="flex items-center gap-3 shrink-0">
          <a
            href={contactHref}
            data-radial-button
            class="site-header__cta group relative hidden sm:inline-flex items-center gap-1.5 text-base font-medium px-6 py-2.5 rounded-full overflow-hidden"
          >
            <span class="relative z-10">{t("nav.cta")}</span>
            <span
              aria-hidden="true"
              class="relative z-10 transition-transform duration-[600ms] group-hover:translate-x-1"
            >→</span>
            <span
              aria-hidden="true"
              data-radial-fill
              style="left: 50%; top: 50%; transition: width 800ms ease-in-out;"
              class="site-header__cta-radial absolute z-0 block aspect-square w-0 -translate-x-1/2 -translate-y-1/2 rounded-full group-hover:w-[225%]"
            ></span>
          </a>

          {/* Language switcher — só desktop (mobile fica no hamburger menu) */}
          <div class="hidden lg:block">
            <LanguageSwitcher />
          </div>

          <button
            type="button"
            class="js-menu-toggle site-header__menu-btn lg:hidden p-2 -m-2"
            aria-label={t("common.openMenu")}
            data-label-open={t("common.openMenu")}
            data-label-close={t("common.closeMenu")}
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <svg
              class="w-7 h-7"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
              />
            </svg>
          </button>
        </div>
      </div>
    </header>
  )
}

<header
  data-header-sticky
  data-scroll-aware={isHome ? "true" : undefined}
  data-visible={isHome ? "false" : "true"}
  class="site-header site-header--sticky"
>
  <div class="site-header__inner max-w-[100rem] mx-auto flex items-center justify-between gap-6">
    <a
      href={heroHref}
      class="site-header__logo flex items-center shrink-0"
      aria-label={t("nav.logoAriaLabel")}
    >
      <img
        src={logoCompleto.src}
        alt={t("brand.logoAlt")}
        width={logoCompleto.width}
        height={logoCompleto.height}
        class="site-header__logo-img w-auto"
        loading="eager"
      />
    </a>

    <nav aria-label={t("nav.mainMenu")} class="hidden lg:block flex-1">
      <ul class="flex items-center justify-center gap-10 lg:gap-14">
        {
          mainNav.map((item) => (
            <li>
              <a
                data-nav-link
                href={localizeAnchor(item.anchor)}
                class="site-header__nav-link inline-flex flex-col items-center gap-1.5 text-base font-medium tracking-wide"
              >
                <span>{t(item.labelKey)}</span>
                <span class="site-header__nav-dot" aria-hidden="true" />
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-3 shrink-0">
      <a
        href={contactHref}
        data-radial-button
        class="site-header__cta group relative hidden sm:inline-flex items-center gap-1.5 text-base font-medium px-6 py-2.5 rounded-full overflow-hidden"
      >
        <span class="relative z-10">{t("nav.cta")}</span>
        <span
          aria-hidden="true"
          class="relative z-10 transition-transform duration-[600ms] group-hover:translate-x-1"
        >→</span>
        <span
          aria-hidden="true"
          data-radial-fill
          style="left: 50%; top: 50%; transition: width 800ms ease-in-out;"
          class="site-header__cta-radial absolute z-0 block aspect-square w-0 -translate-x-1/2 -translate-y-1/2 rounded-full group-hover:w-[225%]"
        ></span>
      </a>

      {/* Language switcher — só desktop */}
      <div class="hidden lg:block">
        <LanguageSwitcher />
      </div>

      <button
        type="button"
        class="js-menu-toggle site-header__menu-btn lg:hidden p-2 -m-2"
        aria-label={t("common.openMenu")}
        data-label-open={t("common.openMenu")}
        data-label-close={t("common.closeMenu")}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          class="w-7 h-7"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile dropdown lives outside the headers so either hamburger
     (hero or sticky) can toggle it, even when one is off-screen. -->
<nav
  id="mobile-menu"
  aria-label={t("nav.mobileMenuAriaLabel")}
  hidden
  class="site-mobile-menu lg:hidden"
>
  <ul class="px-6 py-4 space-y-1">
    {
      mainNav.map((item) => (
        <li>
          <a
            data-nav-link
            href={localizeAnchor(item.anchor)}
            class="site-mobile-link block px-3 py-2.5 rounded-md text-base font-medium transition-colors"
          >
            {t(item.labelKey)}
          </a>
        </li>
      ))
    }
    <li class="pt-3 sm:hidden">
      <a
        href={contactHref}
        class="w-full inline-flex items-center justify-center gap-1.5 bg-brand hover:bg-brand-dark text-paper text-base font-medium px-5 py-3 rounded-full transition-colors"
      >
        {t("nav.cta")}
        <span aria-hidden="true">→</span>
      </a>
    </li>
    <li class="pt-2 border-t border-line/60 mt-2">
      <LanguageSwitcher mode="inline" />
    </li>
  </ul>
</nav>

<style>
  /* ===========================================================
     Two-layer header — Apexus-style.
     Active state e fechamento do mobile menu são client-side
     (scroll spy), já que o site é single-page com anchors.
     =========================================================== */

  .site-header {
    width: 100%;
    left: 0;
    right: 0;
  }

  .site-header__inner {
    height: var(--header-h);
    padding-inline: var(--header-px);
  }

  .site-header__logo-img {
    height: var(--logo-h);
  }

  /* ---------- HERO HEADER (transparent, over the hero) ---------- */
  .site-header--hero {
    position: absolute;
    top: 0;
    z-index: 20;
    background: transparent;
    --header-h: 88px;
    --header-px: 1.5rem;
    --logo-h: 48px;
  }
  @media (min-width: 768px) {
    .site-header--hero {
      --header-h: 128px;
      --header-px: 2rem;
      --logo-h: 56px;
    }
  }
  @media (min-width: 1024px) {
    .site-header--hero {
      --header-h: 144px;
      --header-px: 3.5rem;
      --logo-h: 76px;
    }
  }
  .site-header--hero .site-header__nav-link {
    color: rgba(255, 255, 255, 0.78);
  }
  .site-header--hero .site-header__nav-link:hover,
  .site-header--hero .site-header__nav-link[data-active] {
    color: #ffffff;
  }
  .site-header--hero .site-header__cta {
    background-color: var(--color-paper);
    color: var(--color-ink);
    box-shadow:
      0 10px 15px -3px rgba(0, 0, 0, 0.1),
      0 4px 6px -4px rgba(0, 0, 0, 0.1);
  }
  .site-header--hero .site-header__cta:hover {
    color: var(--color-paper);
  }
  .site-header--hero .site-header__cta-radial {
    background-color: var(--color-brand);
  }
  .site-header--hero .site-header__menu-btn {
    color: var(--color-paper);
  }

  /* ---------- STICKY HEADER (solid, slides in from above) ---------- */
  .site-header--sticky {
    position: fixed;
    top: 0;
    z-index: 40;
    background-color: var(--color-paper);
    border-bottom: 1px solid var(--color-line);
    opacity: 0;
    transform: translateY(-100%);
    transition:
      transform 600ms cubic-bezier(0.43, 0.46, 0.64, 0.66),
      opacity 600ms cubic-bezier(0.43, 0.46, 0.64, 0.66);
    will-change: transform, opacity;

    --header-h: 56px;
    --header-px: 1.5rem;
    --logo-h: 32px;
  }
  @media (min-width: 768px) {
    .site-header--sticky {
      --header-h: 64px;
      --header-px: 2.5rem;
      --logo-h: 48px;
    }
  }
  .site-header--sticky[data-visible="true"] {
    opacity: 1;
    transform: translateY(0);
  }
  .site-header--sticky .site-header__nav-link {
    color: var(--color-ink-muted);
  }
  .site-header--sticky .site-header__nav-link:hover {
    color: var(--color-ink);
  }
  .site-header--sticky .site-header__nav-link[data-active] {
    color: var(--color-brand);
  }
  .site-header--sticky .site-header__cta {
    background-color: var(--color-brand);
    color: var(--color-paper);
  }
  .site-header--sticky .site-header__cta-radial {
    background-color: var(--color-paper);
  }
  .site-header--sticky .site-header__cta:hover {
    color: var(--color-brand);
    border-color: var(--color-brand);
  }
  .site-header--sticky .site-header__menu-btn {
    color: var(--color-ink);
  }

  /* Shared transitions */
  .site-header__nav-link {
    transition: color 200ms ease;
  }
  .site-header__cta {
    border: 2px solid transparent;
    transition: color 600ms ease, border-color 600ms ease;
  }
  .site-header__menu-btn {
    transition: color 200ms ease;
  }

  /* Dot indicator below each nav item */
  .site-header__nav-dot {
    width: 4px;
    height: 4px;
    border-radius: 9999px;
    background: currentColor;
    opacity: 0.3;
    transform: scale(0.85);
    transition:
      opacity 200ms ease,
      transform 200ms ease,
      box-shadow 200ms ease;
  }
  .site-header__nav-link:hover .site-header__nav-dot {
    opacity: 0.6;
  }
  .site-header__nav-link[data-active] .site-header__nav-dot {
    opacity: 1;
    transform: scale(1);
    box-shadow:
      0 0 6px rgba(31, 107, 58, 0.55),
      0 0 12px rgba(31, 107, 58, 0.28);
  }

  /* Mobile dropdown, fixed below the sticky bar */
  .site-mobile-menu {
    position: fixed;
    top: var(--header-h, 56px);
    left: 0;
    right: 0;
    z-index: 35;
    background-color: var(--color-paper);
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }
  @media (min-width: 768px) {
    .site-mobile-menu {
      top: 64px;
    }
  }

  /* Mobile nav link colors driven by data-active (set by scroll spy) */
  .site-mobile-link {
    color: var(--color-ink);
  }
  .site-mobile-link:hover {
    background-color: var(--color-paper-alt);
  }
  .site-mobile-link[data-active] {
    color: var(--color-brand);
    background-color: var(--color-paper-alt);
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header--sticky {
      transition: opacity 200ms ease;
      transform: none;
    }
    .site-header--sticky[data-visible="true"] {
      transform: none;
    }
  }
</style>

<script>
  // ---------- Scroll-aware sticky header (slides in past hero) ----------
  const stickyHeader = document.querySelector<HTMLElement>(
    "[data-header-sticky]"
  );
  const scrollAware = stickyHeader?.dataset.scrollAware === "true";
  const heroHeader = document.querySelector<HTMLElement>("[data-header-hero]");

  if (stickyHeader && scrollAware && heroHeader) {
    const getThreshold = () => {
      const rect = heroHeader.getBoundingClientRect();
      return rect.bottom + window.scrollY;
    };

    let threshold = getThreshold();

    const applyStickyVisibility = () => {
      const visible = window.scrollY > threshold;
      const current = stickyHeader.dataset.visible === "true";
      if (visible !== current) {
        stickyHeader.dataset.visible = visible ? "true" : "false";
      }
    };

    let stickyTicking = false;
    const onScrollSticky = () => {
      if (!stickyTicking) {
        requestAnimationFrame(() => {
          applyStickyVisibility();
          stickyTicking = false;
        });
        stickyTicking = true;
      }
    };

    window.addEventListener("scroll", onScrollSticky, { passive: true });
    window.addEventListener("resize", () => {
      threshold = getThreshold();
      applyStickyVisibility();
    });

    applyStickyVisibility();
  }

  // ---------- Mobile menu toggle ----------
  const toggles = document.querySelectorAll<HTMLButtonElement>(
    ".js-menu-toggle"
  );
  const menu = document.getElementById("mobile-menu");

  const setMenuState = (open: boolean) => {
    if (!menu) return;
    if (open) menu.removeAttribute("hidden");
    else menu.setAttribute("hidden", "");
    toggles.forEach((btn) => {
      btn.setAttribute("aria-expanded", String(open));
      // Labels traduzidos vêm via data-attr setado pelo template (locale-aware)
      const label = open
        ? btn.dataset.labelClose ?? "Close menu"
        : btn.dataset.labelOpen ?? "Open menu";
      btn.setAttribute("aria-label", label);
    });
  };

  toggles.forEach((btn) => {
    btn.addEventListener("click", () => {
      const isOpen = menu && !menu.hasAttribute("hidden");
      setMenuState(!isOpen);
    });
  });

  // ---------- Scroll spy (active state across all nav variants) ----------
  const navLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]")
  );

  const getAnchorId = (link: HTMLAnchorElement): string | null => {
    const href = link.getAttribute("href") ?? "";
    const match = href.match(/#([\w-]+)$/);
    return match ? match[1] : null;
  };

  const idToLinks = new Map<string, HTMLAnchorElement[]>();
  navLinks.forEach((link) => {
    const id = getAnchorId(link);
    if (!id) return;
    if (!idToLinks.has(id)) idToLinks.set(id, []);
    idToLinks.get(id)!.push(link);
  });

  const sections: HTMLElement[] = [];
  idToLinks.forEach((_, id) => {
    const el = document.getElementById(id);
    if (el) sections.push(el);
  });

  let activeId: string | null = null;

  const setActiveId = (id: string | null) => {
    if (id === activeId) return;
    activeId = id;
    idToLinks.forEach((links, sectionId) => {
      links.forEach((link) => {
        if (sectionId === id) {
          link.setAttribute("data-active", "true");
          link.setAttribute("aria-current", "true");
        } else {
          link.removeAttribute("data-active");
          link.removeAttribute("aria-current");
        }
      });
    });
  };

  const updateActive = () => {
    const triggerLine = 100; // ~sticky header height + breathing room
    let bestId: string | null = null;
    let bestTop = -Infinity;
    sections.forEach((section) => {
      const top = section.getBoundingClientRect().top - triggerLine;
      if (top <= 0 && top > bestTop) {
        bestTop = top;
        bestId = section.id;
      }
    });
    setActiveId(bestId);
  };

  let activeTicking = false;
  const onScrollActive = () => {
    if (!activeTicking) {
      requestAnimationFrame(() => {
        updateActive();
        activeTicking = false;
      });
      activeTicking = true;
    }
  };
  window.addEventListener("scroll", onScrollActive, { passive: true });
  window.addEventListener("resize", updateActive);
  updateActive();

  // ---------- Close mobile menu on anchor click ----------
  navLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (menu && !menu.hasAttribute("hidden")) {
        setMenuState(false);
      }
    });
  });
</script>
