---
import { Image } from "astro:assets";
import logoOri from "../../assets/branding/safras-logo-ori.png";
import logoBranco from "../../assets/branding/safras-logo-branco.png";
import { mainNav } from "../../data/navigation";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const isHome = currentPath === "/";
const initialMode = isHome ? "hero" : "normal";
const isActive = (href: string) => {
  const normalized = href.replace(/\/$/, "") || "/";
  return normalized === currentPath;
};
---

<header
  data-header
  data-mode={initialMode}
  data-scroll-aware={isHome ? "true" : undefined}
  class="site-header sticky top-0 z-40"
>
  <div class="site-header__inner max-w-[100rem] mx-auto flex items-center justify-between gap-6">
    <a
      href="/"
      class="site-header__logo flex items-center shrink-0 relative"
      aria-label="Safras & Negócios — Ir para a home"
    >
      <Image
        src={logoBranco}
        alt=""
        height={56}
        class="site-header__logo-img site-header__logo-img--white w-auto"
        loading="eager"
      />
      <Image
        src={logoOri}
        alt="Safras & Negócios"
        height={64}
        class="site-header__logo-img site-header__logo-img--ori absolute inset-y-0 left-0 my-auto w-auto"
        loading="eager"
      />
    </a>

    <nav aria-label="Menu principal" class="hidden lg:block flex-1">
      <ul class="flex items-center justify-center gap-10 lg:gap-14">
        {
          mainNav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                data-active={isActive(item.href) ? "true" : undefined}
                class="site-header__nav-link inline-flex flex-col items-center gap-1.5 text-base font-medium tracking-wide"
              >
                <span>{item.label}</span>
                <span class="site-header__nav-dot" aria-hidden="true" />
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-3 shrink-0">
      <button
        type="button"
        data-open-contact
        class="site-header__cta hidden sm:inline-flex items-center gap-1.5 text-base font-medium px-6 py-2.5 rounded-full"
      >
        Solicitar Serviço
        <span aria-hidden="true">→</span>
      </button>

      <button
        type="button"
        id="mobile-menu-toggle"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="site-header__menu-btn lg:hidden p-2 -m-2"
      >
        <svg
          class="w-7 h-7"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    aria-label="Menu principal (mobile)"
    hidden
    class="lg:hidden border-t border-line bg-paper"
  >
    <ul class="px-6 py-4 space-y-1">
      {
        mainNav.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? "page" : undefined}
              class:list={[
                "block px-3 py-2.5 rounded-md text-base font-medium transition-colors",
                isActive(item.href)
                  ? "text-brand bg-paper-alt"
                  : "text-ink hover:bg-paper-alt",
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li class="pt-3 sm:hidden">
        <button
          type="button"
          data-open-contact
          class="w-full inline-flex items-center justify-center gap-1.5 bg-brand hover:bg-brand-dark text-paper text-base font-medium px-5 py-3 rounded-full transition-colors"
        >
          Solicitar Serviço
          <span aria-hidden="true">→</span>
        </button>
      </li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    transition: background-color 300ms ease, border-color 300ms ease;
    will-change: opacity;
  }

  /* Sizing driven by CSS vars so hero/normal modes can differ with smooth transitions */
  .site-header__inner {
    height: var(--header-h);
    padding-inline: var(--header-px);
    transition: height 300ms ease, padding 300ms ease;
  }
  .site-header__logo-img {
    height: var(--logo-h);
    transition: height 300ms ease, opacity 200ms ease;
  }

  /* --- MODE: hero (over the dark image) — fully transparent, fused with hero --- */
  .site-header[data-mode="hero"] {
    --header-h: 128px;
    --header-px: 2rem;
    --logo-h: 40px;
    background-color: transparent;
    border-bottom: 0;
  }
  @media (min-width: 768px) {
    .site-header[data-mode="hero"] {
      --header-h: 144px;
      --header-px: 3.5rem;
      --logo-h: 56px;
    }
  }
  .site-header[data-mode="hero"] .site-header__logo-img--white {
    opacity: 1;
  }
  .site-header[data-mode="hero"] .site-header__logo-img--ori {
    opacity: 0;
  }
  .site-header[data-mode="hero"] .site-header__nav-link {
    color: rgba(255, 255, 255, 0.75);
  }
  .site-header[data-mode="hero"] .site-header__nav-link:hover,
  .site-header[data-mode="hero"] .site-header__nav-link[data-active] {
    color: #ffffff;
  }
  .site-header[data-mode="hero"] .site-header__cta {
    background-color: var(--color-paper);
    color: var(--color-ink);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1),
      0 4px 6px -4px rgba(0, 0, 0, 0.1);
  }
  .site-header[data-mode="hero"] .site-header__cta:hover {
    background-color: rgba(255, 255, 255, 0.9);
  }
  .site-header[data-mode="hero"] .site-header__menu-btn {
    color: var(--color-paper);
  }

  /* --- MODE: normal (over white content) — solid paper, no glass --- */
  .site-header[data-mode="normal"] {
    --header-h: 56px;
    --header-px: 1.5rem;
    --logo-h: 32px;
    background-color: var(--color-paper);
    border-bottom: 1px solid var(--color-line);
  }
  @media (min-width: 768px) {
    .site-header[data-mode="normal"] {
      --header-h: 64px;
      --header-px: 2.5rem;
      --logo-h: 48px;
    }
  }
  .site-header[data-mode="normal"] .site-header__logo-img--white {
    opacity: 0;
  }
  .site-header[data-mode="normal"] .site-header__logo-img--ori {
    opacity: 1;
  }
  .site-header[data-mode="normal"] .site-header__nav-link {
    color: var(--color-ink-muted);
  }
  .site-header[data-mode="normal"] .site-header__nav-link:hover {
    color: var(--color-ink);
  }
  .site-header[data-mode="normal"] .site-header__nav-link[data-active] {
    color: var(--color-brand);
  }
  .site-header[data-mode="normal"] .site-header__cta {
    background-color: var(--color-brand);
    color: var(--color-paper);
  }
  .site-header[data-mode="normal"] .site-header__cta:hover {
    background-color: var(--color-brand-dark);
  }
  .site-header[data-mode="normal"] .site-header__menu-btn {
    color: var(--color-ink);
  }

  /* Smooth transitions within each mode */
  .site-header__nav-link {
    transition: color 200ms ease;
  }
  .site-header__cta {
    transition: background-color 200ms ease, color 200ms ease;
  }
  .site-header__menu-btn {
    transition: color 200ms ease;
  }

  /* Dot indicator below each nav item (Apexus-style) */
  .site-header__nav-dot {
    width: 4px;
    height: 4px;
    border-radius: 9999px;
    background: currentColor;
    opacity: 0.3;
    transform: scale(0.85);
    transition: opacity 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }
  .site-header__nav-link:hover .site-header__nav-dot {
    opacity: 0.6;
  }
  .site-header__nav-link[data-active] .site-header__nav-dot {
    opacity: 1;
    transform: scale(1);
    box-shadow: 0 0 6px rgba(31, 107, 58, 0.55), 0 0 12px rgba(31, 107, 58, 0.28);
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>("[data-header]");
  const scrollAware = header?.dataset.scrollAware === "true";
  const hero = document.querySelector<HTMLElement>(
    'section[aria-labelledby="hero-titulo"]'
  );

  if (header && scrollAware && hero) {
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    const getHeroBottom = () =>
      hero.getBoundingClientRect().bottom + window.scrollY;

    let heroBottom = getHeroBottom();
    const threshold = () => header.offsetHeight;

    const apply = () => {
      const scroll = window.scrollY;
      const bottom = heroBottom;
      const fadeOutStart = bottom * 0.3;
      const fadeOutEnd = bottom * 0.5;
      const fadeInStart = bottom * 0.5;
      const fadeInEnd = bottom * 0.7;

      if (scroll < fadeOutStart) {
        header.dataset.mode = "hero";
        header.style.opacity = "1";
      } else if (scroll < fadeOutEnd) {
        // Fade out: 30% → 50% of hero
        const p = (scroll - fadeOutStart) / (fadeOutEnd - fadeOutStart);
        header.dataset.mode = "hero";
        header.style.opacity = prefersReducedMotion
          ? "1"
          : String(Math.max(0, 1 - p));
      } else if (scroll < fadeInEnd) {
        // Fade in as normal: 50% → 70% of hero
        const p = (scroll - fadeInStart) / (fadeInEnd - fadeInStart);
        header.dataset.mode = "normal";
        header.style.opacity = prefersReducedMotion ? "1" : String(p);
      } else {
        header.dataset.mode = "normal";
        header.style.opacity = "1";
      }
    };

    let ticking = false;
    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          apply();
          ticking = false;
        });
        ticking = true;
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", () => {
      heroBottom = getHeroBottom();
      apply();
    });

    // Initial
    apply();
  }

  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    if (!menu) return;
    const willOpen = menu.hasAttribute("hidden");
    if (willOpen) {
      menu.removeAttribute("hidden");
    } else {
      menu.setAttribute("hidden", "");
    }
    toggle.setAttribute("aria-expanded", String(willOpen));
    toggle.setAttribute("aria-label", willOpen ? "Fechar menu" : "Abrir menu");
  });
</script>
