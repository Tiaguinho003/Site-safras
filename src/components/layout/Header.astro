---
import { Image } from "astro:assets";
import logoOri from "../../assets/branding/safras-logo-ori.png";
import logoBranco from "../../assets/branding/safras-logo-branco.png";
import { mainNav } from "../../data/navigation";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const isHome = currentPath === "/";
const isActive = (href: string) => {
  const normalized = href.replace(/\/$/, "") || "/";
  return normalized === currentPath;
};
---

{
  isHome && (
    <header
      data-header-hero
      class="site-header site-header--hero"
      aria-label="Cabeçalho sobre o hero"
    >
      <div class="site-header__inner max-w-[100rem] mx-auto flex items-center justify-between gap-6">
        <a
          href="/"
          class="site-header__logo flex items-center shrink-0"
          aria-label="Safras & Negócios — Ir para a home"
        >
          <Image
            src={logoBranco}
            alt="Safras & Negócios"
            height={56}
            class="site-header__logo-img w-auto"
            loading="eager"
          />
        </a>

        <nav aria-label="Menu principal (hero)" class="hidden lg:block flex-1">
          <ul class="flex items-center justify-center gap-10 lg:gap-14">
            {mainNav.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={isActive(item.href) ? "page" : undefined}
                  data-active={isActive(item.href) ? "true" : undefined}
                  class="site-header__nav-link inline-flex flex-col items-center gap-1.5 text-base font-medium tracking-wide"
                >
                  <span>{item.label}</span>
                  <span class="site-header__nav-dot" aria-hidden="true" />
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="flex items-center gap-3 shrink-0">
          <button
            type="button"
            data-open-contact
            class="site-header__cta hidden sm:inline-flex items-center gap-1.5 text-base font-medium px-6 py-2.5 rounded-full"
          >
            Solicitar Serviço
            <span aria-hidden="true">→</span>
          </button>

          <button
            type="button"
            class="js-menu-toggle site-header__menu-btn lg:hidden p-2 -m-2"
            aria-label="Abrir menu"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <svg
              class="w-7 h-7"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
              />
            </svg>
          </button>
        </div>
      </div>
    </header>
  )
}

<header
  data-header-sticky
  data-scroll-aware={isHome ? "true" : undefined}
  data-visible={isHome ? "false" : "true"}
  class="site-header site-header--sticky"
>
  <div class="site-header__inner max-w-[100rem] mx-auto flex items-center justify-between gap-6">
    <a
      href="/"
      class="site-header__logo flex items-center shrink-0"
      aria-label="Safras & Negócios — Ir para a home"
    >
      <Image
        src={logoOri}
        alt="Safras & Negócios"
        height={48}
        class="site-header__logo-img w-auto"
        loading="eager"
      />
    </a>

    <nav aria-label="Menu principal" class="hidden lg:block flex-1">
      <ul class="flex items-center justify-center gap-10 lg:gap-14">
        {
          mainNav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                data-active={isActive(item.href) ? "true" : undefined}
                class="site-header__nav-link inline-flex flex-col items-center gap-1.5 text-base font-medium tracking-wide"
              >
                <span>{item.label}</span>
                <span class="site-header__nav-dot" aria-hidden="true" />
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="flex items-center gap-3 shrink-0">
      <button
        type="button"
        data-open-contact
        class="site-header__cta hidden sm:inline-flex items-center gap-1.5 text-base font-medium px-6 py-2.5 rounded-full"
      >
        Solicitar Serviço
        <span aria-hidden="true">→</span>
      </button>

      <button
        type="button"
        class="js-menu-toggle site-header__menu-btn lg:hidden p-2 -m-2"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          class="w-7 h-7"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile dropdown lives outside the headers so either hamburger
     (hero or sticky) can toggle it, even when one is off-screen. -->
<nav
  id="mobile-menu"
  aria-label="Menu principal (mobile)"
  hidden
  class="site-mobile-menu lg:hidden"
>
  <ul class="px-6 py-4 space-y-1">
    {
      mainNav.map((item) => (
        <li>
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
            class:list={[
              "block px-3 py-2.5 rounded-md text-base font-medium transition-colors",
              isActive(item.href)
                ? "text-brand bg-paper-alt"
                : "text-ink hover:bg-paper-alt",
            ]}
          >
            {item.label}
          </a>
        </li>
      ))
    }
    <li class="pt-3 sm:hidden">
      <button
        type="button"
        data-open-contact
        class="w-full inline-flex items-center justify-center gap-1.5 bg-brand hover:bg-brand-dark text-paper text-base font-medium px-5 py-3 rounded-full transition-colors"
      >
        Solicitar Serviço
        <span aria-hidden="true">→</span>
      </button>
    </li>
  </ul>
</nav>

<style>
  /* ===========================================================
     Two-layer header — Apexus-style.
     The transition between the transparent hero header and the
     solid sticky header is a pure CSS class toggle, fully
     decoupled from scroll position. Scroll speed no longer
     drives opacity, so the motion feels natural.
     =========================================================== */

  .site-header {
    width: 100%;
    left: 0;
    right: 0;
  }

  .site-header__inner {
    height: var(--header-h);
    padding-inline: var(--header-px);
  }

  .site-header__logo-img {
    height: var(--logo-h);
  }

  /* ---------- HERO HEADER (transparent, over the hero) ---------- */
  .site-header--hero {
    position: absolute;
    top: 0;
    z-index: 20;
    background: transparent;
    --header-h: 88px;
    --header-px: 1.5rem;
    --logo-h: 36px;
  }
  @media (min-width: 768px) {
    .site-header--hero {
      --header-h: 128px;
      --header-px: 2rem;
      --logo-h: 40px;
    }
  }
  @media (min-width: 1024px) {
    .site-header--hero {
      --header-h: 144px;
      --header-px: 3.5rem;
      --logo-h: 56px;
    }
  }
  .site-header--hero .site-header__nav-link {
    color: rgba(255, 255, 255, 0.78);
  }
  .site-header--hero .site-header__nav-link:hover,
  .site-header--hero .site-header__nav-link[data-active] {
    color: #ffffff;
  }
  .site-header--hero .site-header__cta {
    background-color: var(--color-paper);
    color: var(--color-ink);
    box-shadow:
      0 10px 15px -3px rgba(0, 0, 0, 0.1),
      0 4px 6px -4px rgba(0, 0, 0, 0.1);
  }
  .site-header--hero .site-header__cta:hover {
    background-color: rgba(255, 255, 255, 0.9);
  }
  .site-header--hero .site-header__menu-btn {
    color: var(--color-paper);
  }

  /* ---------- STICKY HEADER (solid, slides in from above) ---------- */
  .site-header--sticky {
    position: fixed;
    top: 0;
    z-index: 40;
    background-color: var(--color-paper);
    border-bottom: 1px solid var(--color-line);
    opacity: 0;
    transform: translateY(-100%);
    transition:
      transform 600ms cubic-bezier(0.43, 0.46, 0.64, 0.66),
      opacity 600ms cubic-bezier(0.43, 0.46, 0.64, 0.66);
    will-change: transform, opacity;

    --header-h: 56px;
    --header-px: 1.5rem;
    --logo-h: 32px;
  }
  @media (min-width: 768px) {
    .site-header--sticky {
      --header-h: 64px;
      --header-px: 2.5rem;
      --logo-h: 48px;
    }
  }
  .site-header--sticky[data-visible="true"] {
    opacity: 1;
    transform: translateY(0);
  }
  .site-header--sticky .site-header__nav-link {
    color: var(--color-ink-muted);
  }
  .site-header--sticky .site-header__nav-link:hover {
    color: var(--color-ink);
  }
  .site-header--sticky .site-header__nav-link[data-active] {
    color: var(--color-brand);
  }
  .site-header--sticky .site-header__cta {
    background-color: var(--color-brand);
    color: var(--color-paper);
  }
  .site-header--sticky .site-header__cta:hover {
    background-color: var(--color-brand-dark);
  }
  .site-header--sticky .site-header__menu-btn {
    color: var(--color-ink);
  }

  /* Shared transitions */
  .site-header__nav-link {
    transition: color 200ms ease;
  }
  .site-header__cta {
    transition:
      background-color 200ms ease,
      color 200ms ease;
  }
  .site-header__menu-btn {
    transition: color 200ms ease;
  }

  /* Dot indicator below each nav item */
  .site-header__nav-dot {
    width: 4px;
    height: 4px;
    border-radius: 9999px;
    background: currentColor;
    opacity: 0.3;
    transform: scale(0.85);
    transition:
      opacity 200ms ease,
      transform 200ms ease,
      box-shadow 200ms ease;
  }
  .site-header__nav-link:hover .site-header__nav-dot {
    opacity: 0.6;
  }
  .site-header__nav-link[data-active] .site-header__nav-dot {
    opacity: 1;
    transform: scale(1);
    box-shadow:
      0 0 6px rgba(31, 107, 58, 0.55),
      0 0 12px rgba(31, 107, 58, 0.28);
  }

  /* Mobile dropdown, fixed below the sticky bar */
  .site-mobile-menu {
    position: fixed;
    top: var(--header-h, 56px);
    left: 0;
    right: 0;
    z-index: 35;
    background-color: var(--color-paper);
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
  }
  @media (min-width: 768px) {
    .site-mobile-menu {
      top: 64px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header--sticky {
      transition: opacity 200ms ease;
      transform: none;
    }
    .site-header--sticky[data-visible="true"] {
      transform: none;
    }
  }
</style>

<script>
  const stickyHeader = document.querySelector<HTMLElement>(
    "[data-header-sticky]"
  );
  const scrollAware = stickyHeader?.dataset.scrollAware === "true";
  const heroHeader = document.querySelector<HTMLElement>("[data-header-hero]");

  if (stickyHeader && scrollAware && heroHeader) {
    // Threshold = bottom edge of the hero header. Once scrolled past,
    // the sticky variant slides in. Matches Apexus's ScrollTrigger
    // `start: 'bottom 0'` on the transparent header.
    const getThreshold = () => {
      const rect = heroHeader.getBoundingClientRect();
      return rect.bottom + window.scrollY;
    };

    let threshold = getThreshold();

    const apply = () => {
      const visible = window.scrollY > threshold;
      const current = stickyHeader.dataset.visible === "true";
      if (visible !== current) {
        stickyHeader.dataset.visible = visible ? "true" : "false";
      }
    };

    let ticking = false;
    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          apply();
          ticking = false;
        });
        ticking = true;
      }
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", () => {
      threshold = getThreshold();
      apply();
    });

    apply();
  }

  const toggles = document.querySelectorAll<HTMLButtonElement>(
    ".js-menu-toggle"
  );
  const menu = document.getElementById("mobile-menu");

  const setMenuState = (open: boolean) => {
    if (!menu) return;
    if (open) menu.removeAttribute("hidden");
    else menu.setAttribute("hidden", "");
    toggles.forEach((btn) => {
      btn.setAttribute("aria-expanded", String(open));
      btn.setAttribute("aria-label", open ? "Fechar menu" : "Abrir menu");
    });
  };

  toggles.forEach((btn) => {
    btn.addEventListener("click", () => {
      const isOpen = menu && !menu.hasAttribute("hidden");
      setMenuState(!isOpen);
    });
  });
</script>
