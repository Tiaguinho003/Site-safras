---
import { Image } from "astro:assets";
import logoCard from "../../assets/branding/safras-logo-card.png";
import logoBranco from "../../assets/branding/safras-logo-branco.png";
import lavouraAerea from "../../assets/about/lavoura-aerea.png";
import { mainNav } from "../../data/navigation";
import { useTranslation } from "../../i18n";

const { t, localizeAnchor } = useTranslation(Astro);
const currentYear = new Date().getFullYear();

const servicesHref = localizeAnchor("servicos");

// Cada link da coluna "Serviços" no footer aponta pra um dos cards
// da seção #servicos. Reusamos as chaves do dict pra manter consistência
// com o conteúdo da homepage.
const servicesLinks: { dictKey: string; href: string }[] = [
  { dictKey: "services.cards.mercadoNegociacao.title", href: servicesHref },
  { dictKey: "services.cards.analiseQualidade.title", href: servicesHref },
  { dictKey: "services.cards.suporteLogistico.title", href: servicesHref },
];

const socials = [
  {
    label: "Instagram",
    href: "https://instagram.com/safrasnegocios",
    external: true,
  },
  {
    label: "WhatsApp",
    href: "https://wa.me/5535999752377",
    external: true,
  },
];
---

<footer
  class="relative overflow-hidden bg-cover bg-top text-paper"
  style={`background-image: url(${lavouraAerea.src});`}
>
  {/* TOPO: fade branco longo — transição suave + reveal natural da imagem */}
  <div
    aria-hidden="true"
    class="absolute inset-x-0 top-0 h-[55%] bg-gradient-to-b from-paper via-paper/80 to-transparent pointer-events-none z-10"
  ></div>

  {/* BASE: gradient escuro só na parte de baixo — legibilidade das colunas */}
  <div
    aria-hidden="true"
    class="absolute inset-x-0 bottom-0 h-[70%] bg-gradient-to-t from-ink/90 via-ink/65 to-transparent pointer-events-none z-10"
  ></div>

  <div class="relative z-20 max-w-[100rem] mx-auto px-6 md:px-10 pt-4 md:pt-6 lg:pt-8 pb-[3.6rem] md:pb-[4.5rem] lg:pb-[5.4rem]">
    {/* ====== Logo centralizada no topo do rodapé ====== */}
    <div class="text-center mt-6 md:mt-10 lg:mt-12 mb-6 md:mb-16 lg:mb-20">
      <Image
        src={logoCard}
        alt={t("brand.logoAlt")}
        widths={[200, 320, 480]}
        sizes="(min-width: 1024px) 320px, (min-width: 768px) 260px, 200px"
        class="h-auto w-[200px] md:w-[260px] lg:w-[320px] mx-auto"
      />
    </div>

    {/* ====== 4 colunas ====== */}
    <div
      class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr] gap-8 md:gap-12 lg:gap-16"
    >
      {/* Col 1: Logo branco + tagline (escondido no mobile) */}
      <div class="hidden md:block space-y-5 max-w-sm">
        <Image
          src={logoBranco}
          alt={t("brand.logoAlt")}
          widths={[120, 200]}
          sizes="140px"
          class="h-auto w-[140px]"
        />
        <p class="text-sm text-paper/60 leading-relaxed">
          {t("footer.tagline")}
        </p>
      </div>

      {/* Col 2: Serviços (escondido no mobile) */}
      <nav aria-label={t("footer.columns.services")} class="hidden md:block">
        <h3 class="text-base font-medium text-paper mb-5">
          {t("footer.columns.services")}
        </h3>
        <ul class="space-y-3">
          {
            servicesLinks.map((s) => (
              <li>
                <a
                  href={s.href}
                  class="text-sm text-paper/60 hover:text-paper transition-colors"
                >
                  {t(s.dictKey)}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      {/* Col 3: Navegação */}
      <nav aria-label={t("footer.columns.navigation")}>
        <h3 class="text-base font-medium text-paper mb-5">
          {t("footer.columns.navigation")}
        </h3>
        <ul class="space-y-3">
          {
            mainNav.map((item) => (
              <li>
                <a
                  href={localizeAnchor(item.anchor)}
                  class="text-sm text-paper/60 hover:text-paper transition-colors"
                >
                  {t(item.labelKey)}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      {/* Col 4: Sociais */}
      <nav aria-label={t("footer.columns.socials")}>
        <h3 class="text-base font-medium text-paper mb-5">
          {t("footer.columns.socials")}
        </h3>
        <ul class="space-y-3">
          {
            socials.map((s) => (
              <li>
                <a
                  href={s.href}
                  target={s.external ? "_blank" : undefined}
                  rel={s.external ? "noopener noreferrer" : undefined}
                  class="text-sm text-paper/60 hover:text-paper transition-colors"
                >
                  {s.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    {/* ====== Bottom row ====== */}
    <div
      class="mt-8 md:mt-20 pt-5 md:pt-8 border-t border-paper/10 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 text-xs text-paper/50"
    >
      <p>
        © {currentYear} {t("brand.name")}. {t("footer.copyright")}
      </p>
      <div class="flex items-center gap-5">
        <button
          type="button"
          data-scroll-top
          class="inline-flex items-center gap-1.5 hover:text-paper transition-colors"
          aria-label={t("footer.backToTopAriaLabel")}
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 19V5M5 12l7-7 7 7"></path>
          </svg>
          {t("footer.backToTop")}
        </button>
      </div>
    </div>

    {/* ====== Credits row ====== */}
    <div class="mt-5 md:mt-6 pt-4 md:pt-5 border-t border-paper/5 text-center">
      <a
        href="https://wa.me/5511910784384"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block text-xs text-paper/45 hover:text-paper/80 transition-colors"
        aria-label={t("footer.developerAriaLabel")}
      >
        {t("footer.developedBy")} <span class="font-semibold text-paper/70 underline underline-offset-4 decoration-paper/25">{t("footer.developerName")}</span>
      </a>
    </div>
  </div>
</footer>

<script>
  // Back-to-top — usa o helper unificado do BaseLayout (Lenis + fallback)
  document
    .querySelectorAll<HTMLButtonElement>("[data-scroll-top]")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        const smooth = (
          window as Window & {
            __smoothScrollTo?: (target: HTMLElement | number) => void;
          }
        ).__smoothScrollTo;
        if (smooth) {
          smooth(0);
        } else {
          window.scrollTo({ top: 0, behavior: "smooth" });
        }
      });
    });
</script>
