---
import { Image } from "astro:assets";
import logoOri from "../../assets/branding/safras-logo-ori.png";
import { mainNav } from "../../data/navigation";

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-line bg-paper">
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-14 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-16">
      <div class="space-y-5">
        <Image
          src={logoOri}
          alt="Safras & Negócios"
          height={44}
          widths={[160, 320]}
          sizes="160px"
          class="h-9 w-auto"
        />
        <p class="text-sm text-ink-muted leading-relaxed max-w-xs">
          Corretora institucional no mercado de café, conectando produtores,
          cooperativas, indústria e exportadores com seriedade e proximidade.
        </p>
      </div>

      <nav aria-label="Mapa do site">
        <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-muted mb-5">
          Navegação
        </h2>
        <ul class="space-y-3">
          {
            mainNav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-ink hover:text-brand transition-colors"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div>
        <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-muted mb-5">
          Contato
        </h2>
        <ul class="space-y-3 text-sm text-ink">
          <li>
            <span class="text-ink-muted">E-mail:</span>
            <a
              href="mailto:contato@safrasenegocios.com.br"
              class="hover:text-brand transition-colors ml-1"
            >
              contato@safrasenegocios.com.br
            </a>
          </li>
          <li>
            <span class="text-ink-muted">Telefone:</span>
            <span class="ml-1">(00) 0000-0000</span>
          </li>
          <li class="text-ink-muted leading-relaxed">
            Cidade / UF — Brasil
          </li>
        </ul>
        <p class="mt-4 text-xs italic text-ink-muted/70">
          ⚠ Placeholders de contato — substituir antes de publicar
        </p>
        <button
          type="button"
          data-open-contact
          class="mt-5 inline-flex items-center gap-1.5 bg-brand hover:bg-brand-dark text-paper text-sm font-medium px-5 py-2.5 rounded-full transition-colors"
        >
          Solicitar Serviço
          <span aria-hidden="true">→</span>
        </button>
      </div>
    </div>

    <div
      class="mt-14 pt-8 border-t border-line flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 text-xs text-ink-muted"
    >
      <p>© {currentYear} Safras & Negócios. Todos os direitos reservados.</p>
      <p>Brasil</p>
    </div>
  </div>
</footer>
