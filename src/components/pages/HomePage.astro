---
/**
 * HomePage — single source of truth pro conteúdo da home em qualquer idioma.
 *
 * Usado por:
 * - src/pages/index.astro       (PT-BR, /)
 * - src/pages/en/index.astro    (EN, /en/)
 * - src/pages/es/index.astro    (ES, /es/)
 *
 * Todas as 3 rotas renderizam ESTE componente. O locale vem de
 * Astro.currentLocale automaticamente.
 *
 * Strings vêm do dicionário (src/i18n/*.ts) via useTranslation().
 * Anchors/IDs de seção vêm de anchors.ts (servicos→services/servicios, etc.).
 */
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactSection from "../sections/ContactSection.astro";
import { useTranslation, getAnchor } from "../../i18n";

import fachadaSafras from "../../assets/hero/fachada-safras.jpg";
import saoSebastiaoParaiso from "../../assets/about/sao-sebastiao-paraiso.png";
import lavouraCafeAerea from "../../assets/about/lavoura-cafe-aerea.png";
import analiseQualidadeImg from "../../assets/services/analise-qualidade.png";
import mercadoNegociacaoImg from "../../assets/services/mercado-negociacao.png";
import suporteLogisticoImg from "../../assets/services/suporte-logistico.png";

const { t, tArray, locale } = useTranslation(Astro);

// IDs de seção localizados (#servicos em PT, #services em EN, #servicios em ES)
const heroId = getAnchor("hero", locale);
const servicosId = getAnchor("servicos", locale);
const quemSomosId = getAnchor("quem-somos", locale);

// ===== Dados estruturais (não-traduzíveis: ícones/imagens/posições) =====
// As strings vivem no dicionário; cada item tem uma `key` que mapeia
// pra `dict.<section>.cards.<key>.*`

const statsCards = [
  {
    type: "city" as const,
    position: "top" as const,
    dictPath: "about.stats.city",
  },
  {
    type: "counter" as const,
    target: 10,
    position: "bottom" as const,
    dictPath: "about.stats.years",
  },
];

const differentialsData = [
  {
    key: "historia",
    iconSvg: `<path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" /><path d="M3 3v5h5" /><path d="M12 7v5l4 2" />`,
  },
  {
    key: "missao",
    iconSvg: `<circle cx="12" cy="12" r="10" /><circle cx="12" cy="12" r="6" /><circle cx="12" cy="12" r="2" />`,
  },
  {
    key: "visao",
    iconSvg: `<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" /><circle cx="12" cy="12" r="3" />`,
  },
  {
    key: "valores",
    iconSvg: `<circle cx="12" cy="12" r="10" /><path d="m16.24 7.76-1.804 5.411a2 2 0 0 1-1.265 1.265L7.76 16.24l1.804-5.411a2 2 0 0 1 1.265-1.265z" />`,
  },
];

interface ValoresItem {
  name: string;
  body: string;
}
const valoresLead = t("principles.cards.valores.lead");
const valoresItems = tArray<ValoresItem>("principles.cards.valores.items");

const servicesData = [
  {
    key: "mercadoNegociacao",
    iconSvg: `<path d="m11 17 2 2a1 1 0 1 0 3-3" /><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4" /><path d="m21 3 1 11h-2" /><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3" /><path d="M3 4h8" />`,
    image: mercadoNegociacaoImg,
    imagePosition: "50% 35%",
  },
  {
    key: "analiseQualidade",
    iconSvg: `<path d="M17 8h1a4 4 0 1 1 0 8h-1" /><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z" /><line x1="6" x2="6" y1="2" y2="4" /><line x1="10" x2="10" y1="2" y2="4" /><line x1="14" x2="14" y1="2" y2="4" />`,
    image: analiseQualidadeImg,
    imagePosition: "30% 25%",
  },
  {
    key: "suporteLogistico",
    iconSvg: `<path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2" /><path d="M15 18H9" /><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14" /><circle cx="17" cy="18" r="2" /><circle cx="7" cy="18" r="2" />`,
    image: suporteLogisticoImg,
    imagePosition: "55% 50%",
  },
];

// SVG-friendly tokens em arrays do dict (split-text title lines)
const servicesTitleLines = tArray<string[]>("services.titleLines");
const aboutTitleLines = tArray<string[]>("about.titleLines");
const principlesTitleLines = tArray<string[]>("principles.titleLines");

const rotatingWords = tArray<string>("hero.rotatingWords");

// Pré-computa estruturas de spans dos títulos split-text — evita JSX
// com .map() aninhado e ternários complexos que confundem o parser.
const servicesTitle = servicesTitleLines.map((line, lineIdx) => {
  const baseDelay = lineIdx === 0 ? 0 : lineIdx === 1 ? 80 : 240;
  const spans = line.map((word, wordIdx) => {
    const delay = baseDelay + wordIdx * 80;
    const isHighlight =
      lineIdx === servicesTitleLines.length - 1 &&
      wordIdx === line.length - 1;
    const alignTop = lineIdx === 2 && !isHighlight;
    let className = "split-text-word";
    if (isHighlight) {
      className =
        "split-text-word text-brand text-3xl md:text-4xl lg:text-5xl xl:text-6xl relative";
    } else if (alignTop) {
      className = "split-text-word align-top";
    }
    const styleStr = isHighlight
      ? "transition-delay: " + delay + "ms; top: -0.1em; left: 0.05em;"
      : "transition-delay: " + delay + "ms;";
    return { word, className, styleStr };
  });
  return { spans };
});

const aboutTitle = aboutTitleLines.map((line, lineIdx) => {
  const baseDelay = lineIdx === 0 ? 0 : 240;
  const spans = line.map((word, wordIdx) => {
    const delay = baseDelay + wordIdx * 80;
    const isHighlight = lineIdx === 0 && wordIdx === 0;
    const className = isHighlight
      ? "split-text-word text-brand"
      : "split-text-word";
    const styleStr = "transition-delay: " + delay + "ms;";
    return { word, className, styleStr };
  });
  return { spans };
});

const principlesTitle = principlesTitleLines.map((line, lineIdx) => {
  const baseDelay = lineIdx === 0 ? 0 : 80;
  const spans = line.map((word, wordIdx) => {
    const delay = baseDelay + wordIdx * 80;
    const isHighlight = lineIdx === principlesTitleLines.length - 1;
    const className = isHighlight
      ? "split-text-word text-brand"
      : "split-text-word";
    const styleStr = "transition-delay: " + delay + "ms;";
    return { word, className, styleStr };
  });
  return { spans };
});
---

<BaseLayout title={t("meta.siteTitle")} description={t("meta.siteDescription")}>
  <section
    id={heroId}
    class="relative min-h-[97svh] flex flex-col items-center overflow-hidden"
    aria-labelledby="hero-titulo"
  >
    <div class="absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
      <Image
        src={fachadaSafras}
        alt=""
        widths={[1200, 1600, 2000]}
        sizes="100vw"
        class="w-full h-full object-cover opacity-90 object-[72%_center] md:object-center"
        loading="eager"
      />
      <div class="absolute inset-0 bg-black/28"></div>
      <div
        class="absolute inset-0"
        style="background: linear-gradient(90deg, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.55) 20%, rgba(0,0,0,0.28) 45%, rgba(0,0,0,0) 70%), linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0) 65%, rgba(0,0,0,0.45) 100%);"
      >
      </div>
    </div>

    <div
      class="relative max-w-[100rem] w-full mx-auto px-6 md:px-10 pt-[28svh] md:pt-52 text-paper"
    >
      <div class="text-center">
        <span
          class="inline-block text-[11px] md:text-xs font-semibold uppercase tracking-[0.28em] text-paper/85 mb-6 md:mb-8"
        >
          {t("hero.tag")}
        </span>
      </div>

      <h1
        id="hero-titulo"
        class="uppercase md:normal-case leading-[0.95] mx-auto mt-6 md:mt-12 text-center font-light md:font-extralight text-paper text-4xl sm:text-5xl md:text-5xl lg:text-[64px] xl:text-[80px] 2xl:text-[150px] tracking-[-0.01em] md:tracking-[-0.03em]"
      >
        <span class="block">
          <span
            class="word-rotator uppercase font-extralight text-5xl sm:text-6xl md:text-6xl lg:text-[80px] xl:text-[150px] 2xl:text-[120px]"
            aria-live="polite"
          >
            {rotatingWords.map((word, idx) => (
              <span
                class="word-rotator__word"
                data-state={idx === 0 ? "active" : "queued"}
                aria-hidden={idx === 0 ? "false" : "true"}
              >
                {word}
              </span>
            ))}
          </span>
        </span>
        <span
          class="block text-[#b08968] font-normal text-3xl sm:text-4xl md:text-4xl lg:text-[48px] xl:text-[64px] 2xl:text-[80px]"
        >
          {t("hero.suffix")}
        </span>
      </h1>
    </div>

    <div class="absolute bottom-12 md:bottom-2 left-1/2 -translate-x-1/2 w-11/12 max-w-4xl">
      <svg
        viewBox="0 0 1000 480"
        preserveAspectRatio="xMidYMid meet"
        class="w-full h-auto block"
        aria-hidden="true"
        style="filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.35));"
      >
        <path
          d="M 20 460 Q 500 5 980 460 Q 500 9 20 460 Z"
          fill="rgba(255, 255, 255, 0.95)"
        />
      </svg>
      <a
        href={`#${servicosId}`}
        data-radial-button
        class="group absolute left-1/2 top-[48%] -translate-x-1/2 -translate-y-1/2 inline-flex items-center gap-1.5 bg-paper border-2 border-transparent hover:border-paper text-ink hover:text-paper text-sm md:text-base font-medium px-5 py-2.5 rounded-full overflow-hidden whitespace-nowrap shadow-lg transition-colors duration-[600ms]"
      >
        <span class="relative z-10">{t("hero.cta")}</span>
        <span
          aria-hidden="true"
          class="relative z-10 transition-transform duration-[600ms] group-hover:translate-x-1"
        >→</span>
        <span
          aria-hidden="true"
          data-radial-fill
          style="left: 50%; top: 50%; transition: width 800ms ease-in-out;"
          class="absolute z-0 block aspect-square w-0 -translate-x-1/2 -translate-y-1/2 rounded-full bg-brand group-hover:w-[225%]"
        ></span>
      </a>
    </div>

    <button
      type="button"
      data-scroll-next
      data-target-id={servicosId}
      aria-label={t("hero.scrollNextLabel")}
      class="absolute bottom-8 md:bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-paper/70 hover:text-paper transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-paper/80 focus-visible:ring-offset-2 focus-visible:ring-offset-transparent rounded-full p-2"
    >
      <span
        class="relative block w-6 h-10 rounded-full border border-paper/60"
        aria-hidden="true"
      >
        <span
          class="scroll-mouse-dot absolute top-2 inset-x-0 mx-auto w-1 h-2 bg-paper/85 rounded-full"
        ></span>
      </span>
    </button>
  </section>

  <section
    id={servicosId}
    class="bg-paper scroll-mt-[70px] md:scroll-mt-[90px]"
    aria-labelledby="servicos-titulo"
  >
    <div class="max-w-[88rem] mx-auto px-6 md:px-10 py-20 md:py-28 lg:py-32 pb-14 md:pb-20 lg:pb-24">
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-6 mb-20 md:mb-28 lg:mb-32"
      >
        <div>
          <div class="flex items-start gap-6 md:gap-10 lg:gap-14">
            <div class="flex flex-col items-start shrink-0 gap-6">
              <span
                class="inline-block text-xs font-semibold uppercase tracking-[0.22em] text-brand whitespace-nowrap shrink-0 mt-2 md:mt-3 lg:-mt-8"
              >
                {t("services.sectionLabel")}
              </span>

              <div
                class="coffee-bean-float relative w-[100px] h-[100px] md:w-[120px] md:h-[120px] text-brand"
                aria-hidden="true"
              >
                <div class="coffee-bean-tilt w-full h-full">
                  <svg
                    viewBox="0 0 160 160"
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-full h-full"
                  >
                    <g transform="rotate(8 80 80)">
                      <ellipse cx="80" cy="80" rx="36" ry="52" stroke-width="2.5" />
                      <path d="M 80 30 C 98 48, 98 112, 80 130" stroke-width="2" />
                      <path d="M 80 33 C 93 55, 73 105, 80 127" stroke-width="1.8" />
                      <path d="M 80 33 C 87 55, 67 105, 80 127" stroke-width="1.8" />
                    </g>
                  </svg>
                </div>
              </div>
            </div>
            <h2
              id="servicos-titulo"
              data-reveal="split-text"
              class="split-text text-2xl md:text-3xl lg:text-4xl xl:text-5xl font-medium text-ink leading-[1.05] tracking-[-0.03em] mt-12 md:mt-0 lg:-mt-8"
            >
              {servicesTitle.map((titleLine) => (
                <span class="block">
                  {titleLine.spans.flatMap((s, i) =>
                    i === 0
                      ? [<span class={s.className} style={s.styleStr}>{s.word}</span>]
                      : [" ", <span class={s.className} style={s.styleStr}>{s.word}</span>]
                  )}
                </span>
              ))}
            </h2>
          </div>
        </div>

        <div class="lg:-mt-8 max-w-xl fade-in-up" data-reveal="fade-in-up">
          <p class="text-xl md:text-2xl lg:text-3xl text-ink/50 leading-[1.33]">
            {t("services.intro.part1")}{" "}
            <span class="text-brand font-medium">
              {t("services.intro.highlight")}
            </span>{" "}
            {t("services.intro.part2")}
          </p>
          <div
            aria-hidden="true"
            class="mt-8 md:mt-10 h-px lg:h-0.5 w-full bg-ink opacity-20"
          ></div>
        </div>
      </div>

      <div
        id="servicos-accordion"
        class="flex flex-col md:flex-row gap-5 md:gap-6 md:h-[386px]"
      >
        {servicesData.map((service, idx) => {
          const number = t(`services.cards.${service.key}.number`);
          const title = t(`services.cards.${service.key}.title`);
          const imageAlt = t(`services.cards.${service.key}.imageAlt`);
          const description = t(`services.cards.${service.key}.description`);
          return (
            <article
              data-service-card
              data-scroll-active-card
              data-active={idx === 0 ? "true" : "false"}
              class="group relative overflow-hidden rounded-2xl bg-paper-alt border border-dashed border-line cursor-pointer flex-1 md:flex-[1_1_0%] data-[active=true]:md:flex-[3_1_0%] data-[active=true]:border-solid data-[active=true]:border-line min-h-[280px] md:min-h-0 md:h-full transition-[flex,border-color] duration-500 ease-[cubic-bezier(0.29,0,0.2,1)] focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-4"
              tabindex="0"
              aria-label={`${number}: ${title}`}
            >
              <Image
                src={service.image}
                alt={imageAlt}
                widths={[600, 900, 1200]}
                sizes="(min-width: 1024px) 40vw, (min-width: 768px) 50vw, 100vw"
                class="absolute inset-0 w-full h-full object-cover"
                style={`object-position: ${service.imagePosition};`}
                loading="lazy"
              />

              {/* Light overlay (visível em compacto, some quando focado/hover) */}
              <div
                aria-hidden="true"
                class="absolute inset-0 bg-paper-alt/70 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] group-data-[active=true]:opacity-0"
              />

              {/* Dark gradient (aparece quando focado/hover) */}
              <div
                aria-hidden="true"
                class="absolute inset-0 opacity-0 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] group-data-[active=true]:opacity-100"
                style="background: linear-gradient(180deg, rgba(0,0,0,0) 22%, rgba(0,0,0,0.55) 97%);"
              />

              <div class="relative h-full p-5 md:p-6 flex flex-col justify-between gap-4 md:gap-0">
                <div class="flex items-start justify-between gap-4">
                  <div
                    class="w-11 h-11 md:w-12 md:h-12 rounded-xl flex items-center justify-center bg-ink text-paper group-data-[active=true]:bg-paper group-data-[active=true]:text-[#8b5e34] transition-colors duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] shrink-0"
                    aria-hidden="true"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="22"
                      height="22"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      set:html={service.iconSvg}
                    />
                  </div>
                </div>

                <div>
                  <h3 class="sr-only">{title}</h3>

                  <div class="grid" aria-hidden="true">
                    {/* Título mobile-friendly: stays visible, mas flipa de ink → paper quando focado */}
                    <span
                      class="col-start-1 row-start-1 self-end text-[22px] sm:text-[24px] md:text-[28px] lg:text-[30px] font-medium text-ink leading-[1.2] tracking-[-0.02em] md:line-clamp-2 transition-[opacity,color] duration-[300ms] ease-[cubic-bezier(0.48,0,0.11,1)] group-data-[active=true]:md:opacity-0 group-data-[active=true]:max-md:text-paper"
                    >
                      {title}
                    </span>
                    {/* Título desktop-only (grande paper) — usado pelo crossfade no md+ */}
                    <span
                      class="col-start-1 row-start-1 self-end text-[35px] md:text-[40px] lg:text-[48px] font-medium text-paper leading-[1.08] tracking-[-0.05em] line-clamp-2 opacity-0 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] delay-[300ms] group-data-[active=true]:md:opacity-100 hidden md:block"
                    >
                      {title}
                    </span>
                  </div>

                  {/* Descrição mobile com painel "vidro escuro": grid-rows reveal empurra o título pra cima.
                      bg-ink/55 + backdrop-blur dá efeito frosted glass pra leitura do texto sobre a imagem. */}
                  <div class="md:hidden grid grid-rows-[0fr] group-data-[active=true]:grid-rows-[1fr] transition-[grid-template-rows] duration-[400ms] ease-[cubic-bezier(0.4,0,0.2,1)]">
                    <div class="overflow-hidden">
                      <div class="mt-3 bg-ink/55 backdrop-blur-md rounded-xl px-4 py-3">
                        <p class="text-[14px] text-paper leading-[1.55] opacity-0 group-data-[active=true]:opacity-100 transition-opacity duration-[300ms] ease-out delay-[150ms]">
                          {description}
                        </p>
                      </div>
                    </div>
                  </div>

                  <div
                    aria-hidden="true"
                    class="hidden md:block mt-4 md:mt-6 h-1 w-[calc(100%-5px)] rounded bg-white/50 backdrop-blur-lg overflow-hidden opacity-0 transition-opacity duration-[400ms] ease-[cubic-bezier(0.48,0,0.11,1)] group-data-[active=true]:md:opacity-100"
                  >
                    <div
                      class="h-full w-0 bg-white rounded transition-[width] duration-[650ms] ease-[cubic-bezier(0.48,0,0.11,1)] delay-[550ms] group-data-[active=true]:md:w-full"
                    ></div>
                  </div>
                </div>
              </div>

              <div
                aria-hidden="true"
                class="hidden md:block absolute inset-y-0 right-0 w-[200px] bg-black/60 origin-right scale-x-0 transition-transform duration-[150ms] ease-out group-data-[active=true]:scale-x-100 group-data-[active=true]:duration-[900ms] group-data-[active=true]:ease-[cubic-bezier(0.22,1,0.36,1)] group-data-[active=true]:delay-[500ms]"
              ></div>

              <div
                class="hidden md:flex absolute inset-y-0 right-0 w-[200px] p-5 md:p-6 items-center pointer-events-none"
              >
                <p class="text-paper/95 text-[14px] leading-[1.5] font-normal tracking-[0.005em]">
                  {description.split(" ").flatMap((word, i) => [
                    <span
                      class="inline-block opacity-0 translate-y-1 blur-[2px] group-data-[active=true]:opacity-100 group-data-[active=true]:translate-y-0 group-data-[active=true]:blur-none group-data-[active=true]:transition-[opacity,transform,filter] group-data-[active=true]:duration-[550ms] group-data-[active=true]:ease-[cubic-bezier(0.22,1,0.36,1)] group-data-[active=true]:[transition-delay:var(--word-delay)]"
                      style={`--word-delay: ${900 + i * 32}ms;`}
                    >
                      {word}
                    </span>,
                    " ",
                  ])}
                </p>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  {/* Divider sutil entre Serviços e Sobre nós */}
  <div class="bg-paper">
    <div class="max-w-[88rem] mx-auto px-6 md:px-10">
      <div aria-hidden="true" class="h-px bg-line"></div>
    </div>
  </div>

  <section
    id={quemSomosId}
    class="bg-paper scroll-mt-[70px] md:scroll-mt-[90px]"
    aria-labelledby="quem-somos-titulo"
  >
    <div class="max-w-[88rem] mx-auto px-6 md:px-10 pt-14 md:pt-20 lg:pt-24">
      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-6 mb-10 md:mb-14 lg:mb-20"
      >
        <div>
          <div class="flex items-start gap-6 md:gap-10 lg:gap-14">
            <div class="flex flex-col items-start shrink-0 gap-6">
              <span
                class="inline-block text-xs font-semibold uppercase tracking-[0.22em] text-brand whitespace-nowrap shrink-0 mt-2 md:mt-3 lg:mt-12"
              >
                {t("about.sectionLabel")}
              </span>

              <div
                class="coffee-bean-float relative w-[100px] h-[100px] md:w-[120px] md:h-[120px] text-brand"
                aria-hidden="true"
              >
                <div class="coffee-bean-tilt w-full h-full">
                  <svg
                    viewBox="0 0 160 160"
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-full h-full"
                  >
                    <g transform="rotate(8 80 80)">
                      <ellipse cx="80" cy="80" rx="36" ry="52" stroke-width="2.5" />
                      <path d="M 80 30 C 98 48, 98 112, 80 130" stroke-width="2" />
