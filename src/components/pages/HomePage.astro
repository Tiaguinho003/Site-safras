  <script>
    const rotator = document.querySelector<HTMLElement>(".word-rotator");
    if (rotator) {
      const words = Array.from(
        rotator.querySelectorAll<HTMLElement>(".word-rotator__word")
      );
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      if (words.length > 1 && !prefersReducedMotion) {
        let activeIdx = 0;
        const INTERVAL_MS = 3500;
        const TRANSITION_MS = 1100;

        const rotate = () => {
          const nextIdx = (activeIdx + 1) % words.length;
          const current = words[activeIdx];
          const next = words[nextIdx];

          current.setAttribute("data-state", "exit");
          next.setAttribute("data-state", "queued");

          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              next.setAttribute("data-state", "active");
            });
          });

          window.setTimeout(() => {
            current.setAttribute("data-state", "queued");
          }, TRANSITION_MS);

          activeIdx = nextIdx;
        };

        window.setInterval(rotate, INTERVAL_MS);
      }
    }
  </script>

  <script>
    /* ========================================================================
       SCROLL-ACTIVE CARDS (MOBILE ONLY)
       ========================================================================
       Em mobile (<768px) o hover não existe. Substituímos por um sistema de
       "scroll-focus": o card mais centralizado na viewport ganha data-active.
       Isso dispara os mesmos visuais do hover (overlay, descrição, etc).

       Gating:
       - matchMedia("(max-width: 767px)") — só roda em mobile
       - prefers-reduced-motion → respeita escolha do usuário (sem efeito)

       Algoritmo:
       - Agrupa cards por parentElement (Serviços vs Princípios são grupos
         distintos)
       - A cada scroll/resize (throttled via RAF), calcula a distância do
         CENTRO de cada card visível pro CENTRO da viewport
       - O de menor distância ganha data-active="true", os demais "false"
       - Se nenhum card está visível no grupo, todos ficam "false"

       Performance:
       - IntersectionObserver pra saber QUAIS cards estão visíveis (evita
         medir BoundingClientRect de cards offscreen)
       - requestAnimationFrame pra throttle do scroll
       - Apenas attach quando viewport for mobile; detach quando ultrapassar
         o breakpoint (resize)
    ======================================================================== */
    const mql = window.matchMedia("(max-width: 767px)");
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    type CardGroup = {
      parent: HTMLElement;
      cards: HTMLElement[];
      visibleSet: Set<HTMLElement>;
    };

    let groups: CardGroup[] = [];
    let observer: IntersectionObserver | null = null;
    let scrollAttached = false;
    let scrollTicking = false;
    // Salva o estado inicial dos cards pra restaurar quando sair do mobile
    const initialActiveState = new WeakMap<HTMLElement, string>();

    const updateFocusedCards = () => {
      const viewportCenter = window.innerHeight / 2;
      groups.forEach((group) => {
        let bestCard: HTMLElement | null = null;
        let bestDistance = Infinity;
        group.visibleSet.forEach((card) => {
          const rect = card.getBoundingClientRect();
          const cardCenter = rect.top + rect.height / 2;
          const distance = Math.abs(cardCenter - viewportCenter);
          if (distance < bestDistance) {
            bestDistance = distance;
            bestCard = card;
          }
        });
        group.cards.forEach((card) => {
          const shouldBeActive = card === bestCard;
          const currentActive = card.dataset.active === "true";
          if (shouldBeActive !== currentActive) {
            card.dataset.active = shouldBeActive ? "true" : "false";
          }
        });
      });
    };

    const onScroll = () => {
      if (scrollTicking) return;
      scrollTicking = true;
      requestAnimationFrame(() => {
        updateFocusedCards();
        scrollTicking = false;
      });
    };

    const attachMobile = () => {
      if (scrollAttached) return;
      const allCards = Array.from(
        document.querySelectorAll<HTMLElement>("[data-scroll-active-card]")
      );
      if (allCards.length === 0) return;

      // Snapshot inicial pra restaurar se voltar pro desktop
      allCards.forEach((card) => {
        if (!initialActiveState.has(card)) {
          initialActiveState.set(card, card.dataset.active ?? "false");
        }
      });

      // Agrupa por parentElement
      const parentMap = new Map<HTMLElement, HTMLElement[]>();
      allCards.forEach((card) => {
        const parent = card.parentElement;
        if (!parent) return;
        if (!parentMap.has(parent)) parentMap.set(parent, []);
        parentMap.get(parent)!.push(card);
      });

      groups = Array.from(parentMap.entries()).map(([parent, cards]) => ({
        parent,
        cards,
        visibleSet: new Set<HTMLElement>(),
      }));

      // IntersectionObserver pra rastrear visibilidade
      observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const card = entry.target as HTMLElement;
            const group = groups.find((g) => g.cards.includes(card));
            if (!group) return;
            if (entry.isIntersecting) {
              group.visibleSet.add(card);
            } else {
              group.visibleSet.delete(card);
            }
          });
          // Recalcula foco após mudança de visibilidade
          updateFocusedCards();
        },
        { rootMargin: "10% 0px 10% 0px", threshold: 0 }
      );

      allCards.forEach((card) => observer!.observe(card));
      window.addEventListener("scroll", onScroll, { passive: true });
      // Update inicial caso algum card já esteja no centro ao carregar
      requestAnimationFrame(updateFocusedCards);
      scrollAttached = true;
    };

    const detachMobile = () => {
      if (!scrollAttached) return;
      window.removeEventListener("scroll", onScroll);
      observer?.disconnect();
      observer = null;
      // Restaura estado inicial dos cards (data-active original do template)
      groups.forEach((group) => {
        group.cards.forEach((card) => {
          const initial = initialActiveState.get(card) ?? "false";
          card.dataset.active = initial;
        });
      });
      groups = [];
      scrollAttached = false;
    };

    const apply = () => {
      if (prefersReducedMotion) return;
      if (mql.matches) attachMobile();
      else detachMobile();
    };

    // Listener de mudança de viewport (rotação, resize, devtools)
    if (mql.addEventListener) {
      mql.addEventListener("change", apply);
    } else {
      // Fallback Safari < 14
      mql.addListener(apply);
    }
    apply();
  </script>
</BaseLayout>
